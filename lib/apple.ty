    void *CGEventCreate(void *source);
    void *CGEventCreateMouseEvent(
        void *source,
        unsigned int mouseType,
        CGPoint location,
        unsigned int mouseButton
    );
    void *CGEventCreateKeyboardEvent(
        void *source,
        unsigned short virtualKey,
        int keyDown
    );
    void *CGEventCreateScrollWheelEvent(
        void *source,
        unsigned int units,
        unsigned int wheelCount,
        ...
    );
    void *CGEventCreateCopy(const void *event);
    void CGEventPost(unsigned int tap, void *event);
    void CGEventPostToPid(pid_t pid, void *event);
    unsigned int CGEventGetType(void *event);
    void CGEventSetType(void *event, unsigned int type);
    long long CGEventGetIntegerValueField(void *event, unsigned int field);
    void CGEventSetIntegerValueField(void *event, unsigned int field, long long value);
    double CGEventGetDoubleValueField(void *event, unsigned int field);
    void CGEventSetDoubleValueField(void *event, unsigned int field, double value);
    unsigned long long CGEventGetFlags(void *event);
    void CGEventSetFlags(void *event, unsigned long long flags);
    CGPoint CGEventGetLocation(void *event);

    void *CGEventTapCreate(
        unsigned int tap,
        unsigned int place,
        unsigned int options,
        unsigned long long eventsOfInterest,
        void *callback,
        void *userInfo
    );
    void CGEventTapEnable(void *tap, int enable);

    int AXIsProcessTrustedWithOptions(void *options);
