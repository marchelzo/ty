import ffi as c (C!)
import ptr (typed)

const cf = c.dlopen('/System/Library/Frameworks/CoreFoundation.framework/CoreFoundation')
        ?? throw RuntimeError('apple: failed to load CoreFoundation')

const appsvcs = c.dlopen('/System/Library/Frameworks/ApplicationServices.framework/ApplicationServices')
             ?? throw RuntimeError('apple: failed to load ApplicationServices')

const iokit = c.dlopen('/System/Library/Frameworks/IOKit.framework/IOKit')
           ?? throw RuntimeError('apple_iokit: failed to load IOKit')

fn load-sym(name: String, lib: Ptr[Any]) -> Ptr[Any] {
    let sym = c.dlsym(name, lib) ?? throw RuntimeError("apple: symbol not found: {name}")
    c.load(c.ptr, sym)
}

const CGEventField  = c.u32
const CGEventType   = c.u32
const CGEventMask   = c.u64
const CFIndex       = c.long
const CFTimeInterval = c.double
const Boolean       = c.int
