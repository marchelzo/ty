    unsigned int CGDisplayPixelsHigh(unsigned int display);
    CGRect CGDisplayBounds(unsigned int display);
    unsigned int CGDisplayIsActive(unsigned int display);
    unsigned int CGDisplayIsBuiltin(unsigned int display);
    unsigned int CGDisplayIsOnline(unsigned int display);
    int CGGetActiveDisplayList(unsigned int maxDisplays, unsigned int *activeDisplays, unsigned int *displayCount);

    void *CGWindowListCopyWindowInfo(unsigned int option, unsigned int relativeToWindow);

    void *CGDisplayCreateImage(unsigned int displayID);
    void *CGDisplayCreateImageForRect(unsigned int displayID, CGRect rect);

    unsigned int CGWindowLevelForKey(int key);

    void *CGEventSourceCreate(int stateID);
}

