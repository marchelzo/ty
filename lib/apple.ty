C! pub cf fn {
    void CFRelease(const void *cf);
    const void *CFRetain(const void *cf);

    void *CFRunLoopGetMain(void);
    void *CFRunLoopGetCurrent(void);
    int CFRunLoopRunInMode(const void *mode, double seconds, int returnAfterSourceHandled);
    void CFRunLoopAddSource(void *rl, void *source, const void *mode);
    void CFRunLoopRemoveSource(void *rl, void *source, const void *mode);
    void CFRunLoopStop(void *rl);

    void *CFMachPortCreateRunLoopSource(void *allocator, void *port, long order);
    void CFMachPortInvalidate(void *port);

    void *CFDictionaryCreate(
        void *allocator,
        const void **keys,
        const void **values,
        long numValues,
        const void *keyCallBacks,
        const void *valueCallBacks
    );
    long CFDictionaryGetCount(const void *dict);
    const void *CFDictionaryGetValue(const void *dict, const void *key);

    void *CFArrayGetValueAtIndex(const void *arr, long idx);
    long CFArrayGetCount(const void *arr);

    void *CFStringCreateWithCString(void *alloc, const char *cStr, unsigned int encoding);
    int CFStringGetCString(const void *str, char *buffer, long bufferSize, unsigned int encoding);
    long CFStringGetLength(const void *str);

    int CFNumberGetValue(const void *number, long theType, void *valuePtr);
    long CFGetTypeID(const void *cf);
    long CFStringGetTypeID(void);
    long CFNumberGetTypeID(void);
    long CFBooleanGetTypeID(void);
    long CFArrayGetTypeID(void);
    long CFDictionaryGetTypeID(void);
    int CFBooleanGetValue(const void *boolean);

    void *CFNumberCreate(void *allocator, long type, const void *valuePtr);

    void *CFNotificationCenterGetDistributedCenter(void);
    void *CFNotificationCenterGetLocalCenter(void);
    void CFNotificationCenterAddObserver(
        void *center,
        const void *observer,
        void *callBack,
        const void *name,
        const void *object,
        long suspensionBehavior
    );
    void CFNotificationCenterRemoveObserver(
        void *center,
        const void *observer,
        const void *name,
        const void *object
    );
    void CFNotificationCenterPostNotification(
        void *center,
        const void *name,
        const void *object,
        const void *userInfo,
        int deliverImmediately
    );
}


