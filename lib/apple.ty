let __tls::__cf-tids = nil

fn cfval(ref: Ptr[Any]) -> _ {
    let tids = __cf-tids ?? (__cf-tids = {
        string:  CFStringGetTypeID(),
        number:  CFNumberGetTypeID(),
        boolean: CFBooleanGetTypeID(),
        array:   CFArrayGetTypeID(),
        dict:    CFDictionaryGetTypeID()
    })

    let tid = CFGetTypeID(ref)

    if tid == tids.string {
        cfstr-read(ref)
    } else if tid == tids.boolean {
        CFBooleanGetValue(ref) != 0
    } else if tid == tids.number {
        let out = c.auto(c.box(c.i64))
        CFNumberGetValue(ref, CF.kCFNumberSInt64Type, out)
        out[0]
    } else if tid == tids.array {
        let n = CFArrayGetCount(ref)
        [cfval(CFArrayGetValueAtIndex(ref, i)) for i in ..n]
    } else if tid == tids.dict {
        ref
    }
}

fn cfstr(s: String) -> Ptr[Any] {
    let ref = CFStringCreateWithCString(nil, s.cstr(), CF.kStringEncodingUTF8)
    ref ?? throw RuntimeError("CFStringCreateWithCString failed for '{s}'")
}

fn cfstr-read(ref: Ptr[Any]) -> String {
    let len = CFStringGetLength(ref) * 4 + 1
    let buf = c.new(c.char, len)
    defer c.free(buf)
    CFStringGetCString(ref, buf, len, CF.kStringEncodingUTF8)
    c.str(buf)
}

pub const kCFBooleanTrue  = load-sym('kCFBooleanTrue', cf)
pub const kCFBooleanFalse = load-sym('kCFBooleanFalse', cf)

pub const kCFRunLoopDefaultMode = load-sym('kCFRunLoopDefaultMode', cf)
pub const kCFRunLoopCommonModes = load-sym('kCFRunLoopCommonModes', cf)

pub const kCFTypeDictionaryKeyCallBacks   = c.dlsym('kCFTypeDictionaryKeyCallBacks', cf)
pub const kCFTypeDictionaryValueCallBacks = c.dlsym('kCFTypeDictionaryValueCallBacks', cf)

pub const kAXTrustedCheckOptionPrompt = load-sym('kAXTrustedCheckOptionPrompt', appsvcs)

pub const kIOPMAssertionTypeNoDisplaySleep               = cfstr('NoDisplaySleepAssertion')
pub const kIOPMAssertionTypeNoIdleSleep                  = cfstr('NoIdleSleepAssertion')
pub const kIOPMAssertionTypePreventUserIdleDisplaySleep  = cfstr('PreventUserIdleDisplaySleep')
pub const kIOPMAssertionTypePreventUserIdleSystemSleep   = cfstr('PreventUserIdleSystemSleep')

pub const kIOPMAssertionLevelOn  = 255
pub const kIOPMAssertionLevelOff = 0


pub class CFRef {
    __ptr: Ptr[Any]

    init(ptr: Ptr[Any]) {
        __ptr = ptr
    }

    retain!() {
        CFRetain(__ptr)
        self
    }

    release!() {
        if __ptr != nil {
            CFRelease(__ptr)
            __ptr = nil
        }
    }

    __ptr__() { __ptr }

    __free__() {
        release!()
    }
}

pub class CGEvent : IntoPtr[Any] {
    __ref: Ptr[Any]
    __owned: Bool

    init(ref: ?Ptr[Any] = nil, owned: Bool = true) {
        __ref = ref ?? CGEventCreate(nil) ?? throw RuntimeError('CGEventCreate failed')
        __owned = owned
    }

    copy() -> CGEvent {
        CGEvent(CGEventCreateCopy(__ref))
    }

    get-int(field: Int) -> Int {
        CGEventGetIntegerValueField(__ref, field)
    }

    set-int!(field: Int, val: Int) {
        CGEventSetIntegerValueField(__ref, field, val)
        self
    }

    get-float(field: Int) -> Float {
        CGEventGetDoubleValueField(__ref, field)
    }

    set-float!(field: Int, val: Float) {
        CGEventSetDoubleValueField(__ref, field, val)
        self
    }

    event-type -> Int {
        CGEventGetType(__ref)
    }

    event-type=(t: Int) {
        CGEventSetType(__ref, t)
    }

    flags -> Int {
        CGEventGetFlags(__ref)
    }

    flags=(f: Int) {
        CGEventSetFlags(__ref, f)
    }

    post!(tap: Int = cg.kSessionEventTap) {
        CGEventPost(tap, __ref)
    }

    post-to-pid!(pid: Int) {
        CGEventPostToPid(pid, __ref)
    }

    __ptr__() { __ref }

    __free__() {
        if __owned && __ref != nil {
            CFRelease(__ref)
            __ref = nil
        }
    }
}

pub fn key-event(keycode: Int, down?: Bool, source: ?Ptr[Any] = nil) -> CGEvent {
    let ref = CGEventCreateKeyboardEvent(source, keycode, down? ? 1 : 0)
        ?? throw RuntimeError('CGEventCreateKeyboardEvent failed')
    CGEvent(ref)
}

pub fn mouse-event(
    ev-type: Int,
    x: Float,
    y: Float,
    button: Int = 0,
    source: ?Ptr[Any] = nil
) -> CGEvent {
    let pt = c.auto(c.new(c.double, 2))
    pt[0] = x
    pt[1] = y
    let ref = CGEventCreateMouseEvent(source, ev-type, pt, button)
        ?? throw RuntimeError('CGEventCreateMouseEvent failed')
    CGEvent(ref)
}

pub fn scroll-event(dy: Int, dx: Int = 0, source: ?Ptr[Any] = nil) -> CGEvent {
    let ref = CGEventCreateScrollWheelEvent(source, cg.kScrollEventUnitLine, 2, (c.i32, dy), (c.i32, dx))
        ?? throw RuntimeError('CGEventCreateScrollWheelEvent failed')
    CGEvent(ref)
}

pub class EventTap {
    __tap: Ptr[Any]
    __src: Ptr[Any]
    __closure: Ptr[Any]

    init(
        mask: Int,
        callback: _,
        location: Int = cg.kSessionEventTap,
        placement: Int = cg.kHeadInsertEventTap,
        options: Int = cg.kEventTapOptionDefault
    ) {
        C! closure c-cb(proxy: c.ptr, ev-type: c.u32, ev: c.ptr, ctx: c.ptr) -> c.ptr {
            match ev-type {
                cg.kEventTapDisabledByTimeout or
                cg.kEventTapDisabledByUserInput => do {
                    CGEventTapEnable(__tap, 1)
                    ev
                },

                _ => callback(ev-type, CGEvent(ev, owned=false))
            }
        }

        __closure = c-cb

        __tap = CGEventTapCreate(location, placement, options, mask, c-cb, nil)
              ?? throw RuntimeError('CGEventTapCreate failed (check Accessibility permissions)')

        __src = CFMachPortCreateRunLoopSource(nil, __tap, 0)
        CFRunLoopAddSource(CFRunLoopGetMain(), __src, kCFRunLoopCommonModes)
        CGEventTapEnable(__tap, 1)
    }

    enable!() {
        CGEventTapEnable(__tap, 1)
    }

    disable!() {
        CGEventTapEnable(__tap, 0)
    }

    close() {
        if __tap != nil {
            CGEventTapEnable(__tap, 0)
            CFRunLoopRemoveSource(CFRunLoopGetMain(), __src, kCFRunLoopCommonModes)
            CFRelease(__src)
            CFMachPortInvalidate(__tap)
            CFRelease(__tap)
            __tap = nil
        }
    }

    __drop__() {
        close()
    }

    __free__() {
        close()
    }
}

pub ns run-loop {
    pub fn main() -> Ptr[Any] {
        CFRunLoopGetMain()
    }

    pub fn current() -> Ptr[Any] {
        CFRunLoopGetCurrent()
    }

    pub fn run(timeout: Float = 1.0) -> Int {
        CFRunLoopRunInMode(kCFRunLoopDefaultMode, timeout, 1)
    }

    pub fn stop() {
        CFRunLoopStop(CFRunLoopGetMain())
    }
}

pub fn accessibility-trusted?(prompt?: Bool = true) -> Bool {
    let keys = c.auto(c.new(c.ptr, 1))
    let vals = c.auto(c.new(c.ptr, 1))

    keys[0] = kAXTrustedCheckOptionPrompt
    vals[0] = prompt? ? kCFBooleanTrue : kCFBooleanFalse

    let opts = CFDictionaryCreate(
        nil, keys, vals, 1,
        kCFTypeDictionaryKeyCallBacks,
        kCFTypeDictionaryValueCallBacks
    )
    defer CFRelease(opts)

    AXIsProcessTrustedWithOptions(opts) != 0
}

pub ns display {
    pub fn main-id() -> Int {
        CGMainDisplayID()
    }

    pub fn width(id: ?Int) -> Int {
        CGDisplayPixelsWide(id ?? main-id())
    }

    pub fn height(id: ?Int) -> Int {
        CGDisplayPixelsHigh(id ?? main-id())
    }

    pub fn size(id: ?Int) -> (Int, Int) {
        let d = id ?? main-id()
        (CGDisplayPixelsWide(d), CGDisplayPixelsHigh(d))
    }

    pub fn active?(id: Int) -> Bool {
        CGDisplayIsActive(id) != 0
    }

    pub fn builtin?(id: Int) -> Bool {
        CGDisplayIsBuiltin(id) != 0
    }

    pub fn online?(id: Int) -> Bool {
        CGDisplayIsOnline(id) != 0
    }

    pub fn bounds(id: ?Int) -> CGRect {
        CGDisplayBounds(id ?? main-id())
    }

    pub fn list() -> Array[Int] {
        let count = c.auto(c.box(c.u32))
        CGGetActiveDisplayList(0, nil, count)
        let n: Int = count[0]
        if n == 0 { return [] }
        let ids = c.auto(c.new(c.u32, n))
        CGGetActiveDisplayList(n, ids, count)
        [ids[i] for i in ..n]
    }
}

pub fn window-list(
    options: Int = cg.kWindowListOptionOnScreenOnly,
    relative-to: Int = cg.kNullWindowID
) -> Array[Dict[String, _]] {
    let arr = CGWindowListCopyWindowInfo(options, relative-to)
    if arr == nil { return [] }
    defer CFRelease(arr)

    let key-names = [
        'kCGWindowNumber',
        'kCGWindowOwnerPID',
        'kCGWindowOwnerName',
        'kCGWindowName',
        'kCGWindowLayer',
        'kCGWindowAlpha',
        'kCGWindowMemoryUsage',
        'kCGWindowIsOnscreen'
    ]

    let cf-keys = key-names.map(cfstr)
    defer for k in cf-keys { CFRelease(k) }

    let n = CFArrayGetCount(arr)
    let result = []

    for i in ..n {
        let dict = CFArrayGetValueAtIndex(arr, i)
        let entry = %{}
        for name, j in key-names {
            if let $val = CFDictionaryGetValue(dict, cf-keys[j]) {
                entry[name] = cfval(val)
            }
        }
        result.push(entry)
    }

    result
}

pub fn event-source(state: Int = cg.kEventSourceStatePrivate) -> Ptr[Any] | nil {
    CGEventSourceCreate(state)
}

pub class PowerAssertion {
    __id: Int
    __active: Bool

    init(type: Ptr[Any], reason: String) {
        let id-out = c.auto(c.box(c.u32))
        let cf-reason = cfstr(reason)
        defer CFRelease(cf-reason)

        let err = IOPMAssertionCreateWithName(type, kIOPMAssertionLevelOn, cf-reason, id-out)
        if err != 0 {
            throw RuntimeError("IOPMAssertionCreate failed: error {err}")
        }
        __id = id-out[0]
        __active = true
    }

    release!() {
        if __active {
            IOPMAssertionRelease(__id)
            __active = false
        }
    }

    active? -> Bool { __active }

    __free__() { release!() }
}

pub fn prevent-display-sleep(reason: String = 'Ty: prevent display sleep') -> PowerAssertion {
    PowerAssertion(kIOPMAssertionTypeNoDisplaySleep, reason)
}

pub fn prevent-idle-sleep(reason: String = 'Ty: prevent idle sleep') -> PowerAssertion {
    PowerAssertion(kIOPMAssertionTypeNoIdleSleep, reason)
}

