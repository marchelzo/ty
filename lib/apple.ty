pub class CFRef {
    __ptr: Ptr[Any]

    init(ptr: Ptr[Any]) {
        __ptr = ptr
    }

    retain!() {
        CFRetain(__ptr)
        self
    }

    release!() {
        if __ptr != nil {
            CFRelease(__ptr)
            __ptr = nil
        }
    }

    __ptr__() { __ptr }

    __free__() {
        release!()
    }
}

pub class CGEvent : IntoPtr[Any] {
    __ref: Ptr[Any]
    __owned: Bool

    init(ref: ?Ptr[Any] = nil, owned: Bool = true) {
        __ref = ref ?? CGEventCreate(nil) ?? throw RuntimeError('CGEventCreate failed')
        __owned = owned
    }

    copy() -> CGEvent {
        CGEvent(CGEventCreateCopy(__ref))
    }

    get-int(field: Int) -> Int {
        CGEventGetIntegerValueField(__ref, field)
    }

    set-int!(field: Int, val: Int) {
        CGEventSetIntegerValueField(__ref, field, val)
        self
    }

    get-float(field: Int) -> Float {
        CGEventGetDoubleValueField(__ref, field)
    }

    set-float!(field: Int, val: Float) {
        CGEventSetDoubleValueField(__ref, field, val)
        self
    }

    event-type -> Int {
        CGEventGetType(__ref)
    }

    event-type=(t: Int) {
        CGEventSetType(__ref, t)
    }

    flags -> Int {
        CGEventGetFlags(__ref)
    }

    flags=(f: Int) {
        CGEventSetFlags(__ref, f)
    }

    post!(tap: Int = cg.kSessionEventTap) {
        CGEventPost(tap, __ref)
    }

    post-to-pid!(pid: Int) {
        CGEventPostToPid(pid, __ref)
    }

    __ptr__() { __ref }

    __free__() {
        if __owned && __ref != nil {
            CFRelease(__ref)
            __ref = nil
        }
    }
}

pub fn key-event(keycode: Int, down?: Bool, source: ?Ptr[Any] = nil) -> CGEvent {
    let ref = CGEventCreateKeyboardEvent(source, keycode, down? ? 1 : 0)
        ?? throw RuntimeError('CGEventCreateKeyboardEvent failed')
    CGEvent(ref)
}

pub fn mouse-event(
    ev-type: Int,
    x: Float,
    y: Float,
    button: Int = 0,
    source: ?Ptr[Any] = nil
) -> CGEvent {
    let pt = c.auto(c.new(c.double, 2))
    pt[0] = x
    pt[1] = y
    let ref = CGEventCreateMouseEvent(source, ev-type, pt, button)
        ?? throw RuntimeError('CGEventCreateMouseEvent failed')
    CGEvent(ref)
}

pub fn scroll-event(dy: Int, dx: Int = 0, source: ?Ptr[Any] = nil) -> CGEvent {
    let ref = CGEventCreateScrollWheelEvent(source, cg.kScrollEventUnitLine, 2, (c.i32, dy), (c.i32, dx))
        ?? throw RuntimeError('CGEventCreateScrollWheelEvent failed')
    CGEvent(ref)
}

pub class EventTap {
    __tap: Ptr[Any]
    __src: Ptr[Any]
    __closure: Ptr[Any]

    init(
        mask: Int,
        callback: _,
        location: Int = cg.kSessionEventTap,
        placement: Int = cg.kHeadInsertEventTap,
        options: Int = cg.kEventTapOptionDefault
    ) {
        C! closure c-cb(proxy: c.ptr, ev-type: c.u32, ev: c.ptr, ctx: c.ptr) -> c.ptr {
            match ev-type {
                cg.kEventTapDisabledByTimeout or
                cg.kEventTapDisabledByUserInput => do {
                    CGEventTapEnable(__tap, 1)
                    ev
                },

                _ => callback(ev-type, CGEvent(ev, owned=false))
            }
        }

        __closure = c-cb

        __tap = CGEventTapCreate(location, placement, options, mask, c-cb, nil)
              ?? throw RuntimeError('CGEventTapCreate failed (check Accessibility permissions)')

        __src = CFMachPortCreateRunLoopSource(nil, __tap, 0)
        CFRunLoopAddSource(CFRunLoopGetMain(), __src, kCFRunLoopCommonModes)
        CGEventTapEnable(__tap, 1)
    }

    enable!() {
        CGEventTapEnable(__tap, 1)
    }

    disable!() {
        CGEventTapEnable(__tap, 0)
    }

    close() {
        if __tap != nil {
            CGEventTapEnable(__tap, 0)
            CFRunLoopRemoveSource(CFRunLoopGetMain(), __src, kCFRunLoopCommonModes)
            CFRelease(__src)
            CFMachPortInvalidate(__tap)
            CFRelease(__tap)
            __tap = nil
        }
    }

    __drop__() {
        close()
    }

    __free__() {
        close()
    }
}

pub ns run-loop {
    pub fn main() -> Ptr[Any] {
        CFRunLoopGetMain()
    }

    pub fn current() -> Ptr[Any] {
        CFRunLoopGetCurrent()
    }

    pub fn run(timeout: Float = 1.0) -> Int {
        CFRunLoopRunInMode(kCFRunLoopDefaultMode, timeout, 1)
    }

    pub fn stop() {
        CFRunLoopStop(CFRunLoopGetMain())
    }
}

pub fn accessibility-trusted?(prompt?: Bool = true) -> Bool {
    let keys = c.auto(c.new(c.ptr, 1))
    let vals = c.auto(c.new(c.ptr, 1))

    keys[0] = kAXTrustedCheckOptionPrompt
    vals[0] = prompt? ? kCFBooleanTrue : kCFBooleanFalse

    let opts = CFDictionaryCreate(
        nil, keys, vals, 1,
        kCFTypeDictionaryKeyCallBacks,
        kCFTypeDictionaryValueCallBacks
    )
    defer CFRelease(opts)

    AXIsProcessTrustedWithOptions(opts) != 0
}

pub ns display {
    pub fn main-id() -> Int {
        CGMainDisplayID()
    }

    pub fn width(id: ?Int) -> Int {
        CGDisplayPixelsWide(id ?? main-id())
    }

    pub fn height(id: ?Int) -> Int {
        CGDisplayPixelsHigh(id ?? main-id())
    }

    pub fn size(id: ?Int) -> (Int, Int) {
        let d = id ?? main-id()
        (CGDisplayPixelsWide(d), CGDisplayPixelsHigh(d))
    }

    pub fn active?(id: Int) -> Bool {
        CGDisplayIsActive(id) != 0
    }

    pub fn builtin?(id: Int) -> Bool {
        CGDisplayIsBuiltin(id) != 0
    }

    pub fn online?(id: Int) -> Bool {
        CGDisplayIsOnline(id) != 0
    }

    pub fn bounds(id: ?Int) -> CGRect {
        CGDisplayBounds(id ?? main-id())
    }

    pub fn list() -> Array[Int] {
        let count = c.auto(c.box(c.u32))
        CGGetActiveDisplayList(0, nil, count)
        let n: Int = count[0]
        if n == 0 { return [] }
        let ids = c.auto(c.new(c.u32, n))
        CGGetActiveDisplayList(n, ids, count)
        [ids[i] for i in ..n]
    }
}

pub fn window-list(
    options: Int = cg.kWindowListOptionOnScreenOnly,
    relative-to: Int = cg.kNullWindowID
) -> Array[Dict[String, _]] {
    let arr = CGWindowListCopyWindowInfo(options, relative-to)
    if arr == nil { return [] }
    defer CFRelease(arr)

    let key-names = [
        'kCGWindowNumber',
        'kCGWindowOwnerPID',
        'kCGWindowOwnerName',
        'kCGWindowName',
        'kCGWindowLayer',
        'kCGWindowAlpha',
        'kCGWindowMemoryUsage',
        'kCGWindowIsOnscreen'
    ]

    let cf-keys = key-names.map(cfstr)
    defer for k in cf-keys { CFRelease(k) }

    let n = CFArrayGetCount(arr)
    let result = []

    for i in ..n {
        let dict = CFArrayGetValueAtIndex(arr, i)
        let entry = %{}
        for name, j in key-names {
            if let $val = CFDictionaryGetValue(dict, cf-keys[j]) {
                entry[name] = cfval(val)
            }
        }
        result.push(entry)
    }

    result
}

pub fn event-source(state: Int = cg.kEventSourceStatePrivate) -> Ptr[Any] | nil {
    CGEventSourceCreate(state)
}

pub class PowerAssertion {
    __id: Int
    __active: Bool

    init(type: Ptr[Any], reason: String) {
        let id-out = c.auto(c.box(c.u32))
        let cf-reason = cfstr(reason)
        defer CFRelease(cf-reason)

        let err = IOPMAssertionCreateWithName(type, kIOPMAssertionLevelOn, cf-reason, id-out)
        if err != 0 {
            throw RuntimeError("IOPMAssertionCreate failed: error {err}")
        }
        __id = id-out[0]
        __active = true
    }

    release!() {
        if __active {
            IOPMAssertionRelease(__id)
            __active = false
        }
    }

    active? -> Bool { __active }

    __free__() { release!() }
}

pub fn prevent-display-sleep(reason: String = 'Ty: prevent display sleep') -> PowerAssertion {
    PowerAssertion(kIOPMAssertionTypeNoDisplaySleep, reason)
}

pub fn prevent-idle-sleep(reason: String = 'Ty: prevent idle sleep') -> PowerAssertion {
    PowerAssertion(kIOPMAssertionTypeNoIdleSleep, reason)
}

pub ns scroll-fields {
    pub const DELTA_AXIS1         = 11
    pub const DELTA_AXIS2         = 12
    pub const FIXED_PT_AXIS1      = 93
    pub const FIXED_PT_AXIS2      = 94
    pub const POINT_DELTA_AXIS1   = 96
    pub const POINT_DELTA_AXIS2   = 97
    pub const SCROLL_PHASE        = 99
    pub const SCROLL_COUNT        = 100
    pub const MOMENTUM_PHASE      = 123
}

pub fn mouse-location() -> (Float, Float) {
    let ev = CGEvent()
    let loc = CGEventGetLocation(ev)
    return {x: loc.x, y: loc.y}
}

const audiotoolbox = c.dlopen('/System/Library/Frameworks/AudioToolbox.framework/AudioToolbox')
                   ?? throw RuntimeError('apple: failed to load AudioToolbox')

const coreaudio = c.dlopen('/System/Library/Frameworks/CoreAudio.framework/CoreAudio')
               ?? throw RuntimeError('apple: failed to load CoreAudio')

const OSStatus          = c.i32
const AudioFormatID     = c.u32
const AudioFormatFlags  = c.u32

C! pub struct AudioStreamBasicDescription {
    c.double mSampleRate;
    c.u32 mFormatID;
    c.u32 mFormatFlags;
    c.u32 mBytesPerPacket;
    c.u32 mFramesPerPacket;
    c.u32 mBytesPerFrame;
    c.u32 mChannelsPerFrame;
    c.u32 mBitsPerChannel;
    c.u32 mReserved;
}

C! pub struct AudioQueueBuffer {
    c.u32 mAudioDataBytesCapacity;
    c.ptr mAudioData;
    c.u32 mAudioDataByteSize;
    c.ptr mUserData;
    c.u32 mPacketDescriptionCapacity;
    c.ptr mPacketDescriptions;
    c.u32 mPacketDescriptionCount;
}

C! struct AudioComponentDescription {
    c.u32 componentType;
    c.u32 componentSubType;
    c.u32 componentManufacturer;
    c.u32 componentFlags;
    c.u32 componentFlagsMask;
}

C! struct AURenderCallbackStruct {
    c.ptr inputProc;
    c.ptr inputProcRefCon;
}

C! struct AudioBuffer {
    c.u32 mNumberChannels;
    c.u32 mDataByteSize;
    c.ptr mData;
}

C! struct AudioBufferList {
    c.u32 mNumberBuffers;
    AudioBuffer mBuffers;
}

C! struct AudioObjectPropertyAddress {
    c.u32 mSelector;
    c.u32 mScope;
    c.u32 mElement;
}

C! audiotoolbox fn {
    int AudioQueueNewOutput(
        const void *inFormat,
        void *inCallbackProc,
        void *inUserData,
        void *inCallbackRunLoop,
        void *inCallbackRunLoopMode,
        unsigned int inFlags,
        void **outAQ
    );

    int AudioQueueNewInput(
        const void *inFormat,
        void *inCallbackProc,
        void *inUserData,
        void *inCallbackRunLoop,
        void *inCallbackRunLoopMode,
        unsigned int inFlags,
        void **outAQ
    );

    int AudioQueueDispose(void *inAQ, int inImmediate);

    int AudioQueueAllocateBuffer(
        void *inAQ,
        unsigned int inBufferByteSize,
        void **outBuffer
    );

    int AudioQueueFreeBuffer(void *inAQ, void *inBuffer);

    int AudioQueueEnqueueBuffer(
        void *inAQ,
        void *inBuffer,
        unsigned int inNumPacketDescs,
        const void *inPacketDescs
    );

    int AudioQueueStart(void *inAQ, const void *inStartTime);
    int AudioQueueStop(void *inAQ, int inImmediate);
    int AudioQueuePause(void *inAQ);
    int AudioQueueFlush(void *inAQ);
    int AudioQueueReset(void *inAQ);

    int AudioQueuePrime(
        void *inAQ,
        unsigned int inNumberOfFramesToPrepare,
        unsigned int *outNumberOfFramesPrepared
    );

    int AudioQueueSetParameter(void *inAQ, unsigned int inParamID, float inValue);
    int AudioQueueGetParameter(void *inAQ, unsigned int inParamID, float *outValue);

    int AudioQueueGetProperty(
        void *inAQ,
        unsigned int inID,
        void *outData,
        unsigned int *ioDataSize
    );

    int AudioQueueSetProperty(
        void *inAQ,
        unsigned int inID,
        const void *inData,
        unsigned int inDataSize
    );

    void *AudioComponentFindNext(void *inComponent, const void *inDesc);
    int AudioComponentInstanceNew(void *inComponent, void **outInstance);
    int AudioComponentInstanceDispose(void *inInstance);

    int AudioUnitInitialize(void *inUnit);
    int AudioUnitUninitialize(void *inUnit);
    int AudioOutputUnitStart(void *inUnit);
    int AudioOutputUnitStop(void *inUnit);

    int AudioUnitSetProperty(
        void *inUnit,
        unsigned int inID,
        unsigned int inScope,
        unsigned int inElement,
        const void *inData,
        unsigned int inDataSize
    );

    int AudioUnitGetProperty(
        void *inUnit,
        unsigned int inID,
        unsigned int inScope,
        unsigned int inElement,
        void *outData,
        unsigned int *ioDataSize
    );
}

C! coreaudio fn {
    int AudioObjectGetPropertyData(
        unsigned int inObjectID,
        const void *inAddress,
        unsigned int inQualifierDataSize,
        const void *inQualifierData,
        unsigned int *ioDataSize,
        void *outData
    );

    int AudioObjectAddPropertyListener(
        unsigned int inObjectID,
        const void *inAddress,
        void *inListener,
        void *inClientData
    );

    int AudioObjectRemovePropertyListener(
        unsigned int inObjectID,
        const void *inAddress,
        void *inListener,
        void *inClientData
    );
}

pub ns audio {
    pub const FORMAT_LINEAR_PCM = 1819304813

    pub const FORMAT_FLAG_FLOAT             = (1 << 0)
    pub const FORMAT_FLAG_BIG_ENDIAN        = (1 << 1)
    pub const FORMAT_FLAG_SIGNED_INTEGER    = (1 << 2)
    pub const FORMAT_FLAG_PACKED            = (1 << 3)
    pub const FORMAT_FLAG_ALIGNED_HIGH      = (1 << 4)
    pub const FORMAT_FLAG_NON_INTERLEAVED   = (1 << 5)
    pub const FORMAT_FLAG_NON_MIXABLE       = (1 << 6)

    pub const FORMAT_NATIVE_FLOAT_PACKED = FORMAT_FLAG_FLOAT | FORMAT_FLAG_PACKED

    pub const QUEUE_PARAM_VOLUME          = 1
    pub const QUEUE_PARAM_PLAYBACK_RATE   = 2
    pub const QUEUE_PARAM_PITCH           = 3
    pub const QUEUE_PARAM_VOLUME_RAMP_TIME = 4

    pub const QUEUE_PROPERTY_IS_RUNNING          = 1634824814
    pub const QUEUE_PROPERTY_STREAM_DESCRIPTION  = 1634821748

    pub const kAudioUnitType_Output              = 1635086197
    pub const kAudioUnitSubType_DefaultOutput    = 1684366880
    pub const kAudioUnitManufacturer_Apple       = 1634758764
    pub const kAudioUnitScope_Input              = 1
    pub const kAudioUnitScope_Output             = 2
    pub const kAudioUnitScope_Global             = 0
    pub const kAudioUnitProperty_SetRenderCallback = 23
    pub const kAudioUnitProperty_StreamFormat      = 8

    pub const kAudioObjectSystemObject                       = 1
    pub const kAudioHardwarePropertyDefaultOutputDevice      = 1682929012
    pub const kAudioHardwarePropertyDefaultSystemOutputDevice = 1934587508
    pub const kAudioHardwarePropertyDefaultInputDevice       = 1682533920
    pub const kAudioHardwarePropertyDevices                  = 1684370979
    pub const kAudioDevicePropertyBufferFrameSize            = 1718839674
    pub const kAudioDevicePropertySafetyOffset               = 1935895663
    pub const kAudioDevicePropertyNominalSampleRate          = 1853059700
    pub const kAudioDevicePropertyAvailableNominalSampleRates = 1853059683
    pub const kAudioDevicePropertyStreams                    = 1937009955
    pub const kAudioObjectPropertyScopeGlobal                = 1735159650
    pub const kAudioObjectPropertyScopeOutput                = 1869968496
    pub const kAudioObjectPropertyScopeInput                 = 1768845428
    pub const kAudioObjectPropertyElementMain                = 0

    pub fn pcm-format(
        sample-rate: Float = 44100.0,
        channels: Int = 2,
        bits: Int = 32,
        float?: Bool = true
    ) -> AudioStreamBasicDescription {
        let bytes-per-sample = bits / 8
        let flags = float?
            ? (FORMAT_FLAG_FLOAT | FORMAT_FLAG_PACKED)
            : (FORMAT_FLAG_SIGNED_INTEGER | FORMAT_FLAG_PACKED)

        AudioStreamBasicDescription(
            mSampleRate=sample-rate,
            mFormatID=FORMAT_LINEAR_PCM,
            mFormatFlags=flags,
            mBytesPerPacket=bytes-per-sample * channels,
            mFramesPerPacket=1,
            mBytesPerFrame=bytes-per-sample * channels,
            mChannelsPerFrame=channels,
            mBitsPerChannel=bits,
            mReserved=0
        )
    }

    pub fn default-output-device() -> Int {
        let addr = AudioObjectPropertyAddress(
            mSelector=kAudioHardwarePropertyDefaultOutputDevice,
            mScope=kAudioObjectPropertyScopeGlobal,
            mElement=kAudioObjectPropertyElementMain
        )
        let dev  = c.auto(c.box(c.u32))
        let size = c.auto(c.box(c.u32))
        size[0] = 4

        let err = AudioObjectGetPropertyData(
            kAudioObjectSystemObject, addr.get(), 0, nil, size, dev
        )
        if err != 0 {
            throw RuntimeError("AudioObjectGetPropertyData (default device) failed: {err}")
        }

        dev[0]
    }

    pub fn device-buffer-frame-size(device: Int = -1) -> Int {
        let dev = device == -1 ? default-output-device() : device

        let addr = AudioObjectPropertyAddress(
            mSelector=kAudioDevicePropertyBufferFrameSize,
            mScope=kAudioObjectPropertyScopeGlobal,
            mElement=kAudioObjectPropertyElementMain
        )
        let frames = c.auto(c.box(c.u32))
        let size   = c.auto(c.box(c.u32))
        size[0] = 4

        let err = AudioObjectGetPropertyData(
            dev, addr.get(), 0, nil, size, frames
        )
        if err != 0 {
            throw RuntimeError("AudioObjectGetPropertyData (buffer frame size) failed: {err}")
        }

        frames[0]
    }

    pub class DeviceListener {
        __callback: Ptr[Any]
        __addr: AudioObjectPropertyAddress
        __queue: SharedQueue

        init(queue: SharedQueue) {
            __queue = queue

            __addr = AudioObjectPropertyAddress(
                mSelector=kAudioHardwarePropertyDefaultOutputDevice,
                mScope=kAudioObjectPropertyScopeGlobal,
                mElement=kAudioObjectPropertyElementMain
            )

            C! closure on-change(
                obj:       c.u32,
                n_addrs:   c.u32,
                addrs:     c.ptr,
                user_data: c.ptr
            ) -> c.i32 {
                __queue.put(true)
                return 0
            }

            __callback = on-change

            let err = AudioObjectAddPropertyListener(
                kAudioObjectSystemObject,
                __addr.get(),
                on-change,
                nil
            )
            if err != 0 {
                throw RuntimeError("AudioObjectAddPropertyListener failed: {err}")
            }
        }

        close() {
            if __callback != nil {
                AudioObjectRemovePropertyListener(
                    kAudioObjectSystemObject,
                    __addr.get(),
                    __callback,
                    nil
                )
                __callback = nil
            }
        }

        __drop__() { close() }
        __free__() { close() }
    }
}

pub class AudioQueue {
    __queue: Ptr[Any]
    __buffers: Array[Ptr[Any]]
    __callback: Ptr[Any]
    __format: AudioStreamBasicDescription
    __fill: _
    __started: Bool
    __thread: Thread

    init(
        format: AudioStreamBasicDescription = audio.pcm-format(),
        buffer-size: Int = 4096,
        buffer-count: Int = 3,
        fill: _
    ) {
        __format = format
        __fill = fill
        __started = false
        __buffers = []

        let rl-ready = SharedQueue()

        __thread = Thread(fn () {
            rl-ready.put(CFRunLoopGetCurrent())
            for (;;) {
                if CFRunLoopRunInMode(kCFRunLoopDefaultMode, 1e9, 0) == CF.kCFRunLoopRunFinished {
                    os.sleep(0.001)
                }
            }
        }, isolated=true)

        let aq-run-loop = rl-ready.take()

        C! closure aq-cb(user: c.ptr, aq: c.ptr, buf: c.ptr) -> c.void {
            __refill(buf)
        }

        __callback = aq-cb

        let out = c.auto(c.box(c.ptr))
        let err = AudioQueueNewOutput(
            format.get(), aq-cb, nil,
            aq-run-loop, kCFRunLoopDefaultMode,
            0, out
        )
        if err != 0 {
            throw RuntimeError("AudioQueueNewOutput failed: {err}")
        }
        __queue = out[0]

        for _ in ..buffer-count {
            let buf-out = c.auto(c.box(c.ptr))
            let err = AudioQueueAllocateBuffer(__queue, buffer-size, buf-out)
            if err != 0 {
                AudioQueueDispose(__queue, 1)
                throw RuntimeError("AudioQueueAllocateBuffer failed: {err}")
            }
            __buffers.push(buf-out[0])
        }
    }

    __refill(buf-ptr: Ptr[Any]) {
        let buf = AudioQueueBuffer(buf-ptr)
        let capacity = buf.mAudioDataBytesCapacity
        let data = buf.mAudioData
        let bytes-per-frame = __format.mBytesPerFrame
        let frames = capacity / bytes-per-frame

        __fill(typed(data, c.float), frames, __format.mChannelsPerFrame)

        buf.mAudioDataByteSize = capacity
        AudioQueueEnqueueBuffer(__queue, buf-ptr, 0, nil)
    }

    start!() {
        if !__started {
            for buf in __buffers { __refill(buf) }
            __started = true
        }
        let err = AudioQueueStart(__queue, nil)
        if err != 0 {
            throw RuntimeError("AudioQueueStart failed: {err}")
        }
        self
    }

    stop!(immediate?: Bool = true) {
        if __started {
            AudioQueueStop(__queue, immediate? ? 1 : 0)
            __started = false
        }
        self
    }

    pause!() {
        AudioQueuePause(__queue)
        self
    }

    unpause!() {
        AudioQueueStart(__queue, nil)
        self
    }

    flush!() {
        AudioQueueFlush(__queue)
        self
    }

    reset!() {
        AudioQueueReset(__queue)
        self
    }

    volume=(v: Float) {
        AudioQueueSetParameter(__queue, audio.QUEUE_PARAM_VOLUME, v)
    }

    volume -> Float {
        let out = c.auto(c.box(c.float))
        AudioQueueGetParameter(__queue, audio.QUEUE_PARAM_VOLUME, out)
        out[0]
    }

    running? -> Bool {
        let out = c.auto(c.box(c.u32))
        let size = c.auto(c.box(c.u32))
        size[0] = 4
        AudioQueueGetProperty(__queue, audio.QUEUE_PROPERTY_IS_RUNNING, out, size)
        out[0] != 0
    }

    close() {
        if __queue != nil {
            AudioQueueStop(__queue, 1)
            AudioQueueDispose(__queue, 1)
            __queue = nil
            __started = false
        }
    }

    __drop__() { close() }
    __free__() { close() }
}

pub class AudioOutput {
    __unit: Ptr[Any]
    __callback: Ptr[Any]
    __format: AudioStreamBasicDescription
    __running: Bool

    init(
        format: AudioStreamBasicDescription = audio.pcm-format(),
        render: _
    ) {
        __format = format
        __running = false

        let desc = AudioComponentDescription(
            componentType=audio.kAudioUnitType_Output,
            componentSubType=audio.kAudioUnitSubType_DefaultOutput,
            componentManufacturer=audio.kAudioUnitManufacturer_Apple,
            componentFlags=0,
            componentFlagsMask=0
        )

        let comp = AudioComponentFindNext(nil, desc)
        if comp == nil {
            throw RuntimeError("AudioComponentFindNext: no default output component")
        }

        let unit-out = c.auto(c.box(c.ptr))
        let err = AudioComponentInstanceNew(comp, unit-out)
        if err != 0 {
            throw RuntimeError("AudioComponentInstanceNew failed: {err}")
        }
        __unit = unit-out[0]

        err = AudioUnitSetProperty(
            __unit,
            audio.kAudioUnitProperty_StreamFormat,
            audio.kAudioUnitScope_Input, 0,
            format.get(), #format
        )
        if err != 0 {
            AudioComponentInstanceDispose(__unit)
            throw RuntimeError("AudioUnitSetProperty (StreamFormat) failed: {err}")
        }

        let channels: Int = format.mChannelsPerFrame

        C! closure au-render(
            ref_con:     c.ptr,
            flags:       c.ptr,
            timestamp:   c.ptr,
            bus:         c.u32,
            frames:      c.u32,
            buffer_list: c.ptr
        ) -> c.i32 {
            let data = c.load(c.ptr, buffer_list + 16)
            render(data, frames, channels)
            return 0
        }

        __callback = au-render

        let cb = AURenderCallbackStruct(
            inputProc=au-render,
            inputProcRefCon=nil
        )

        err = AudioUnitSetProperty(
            __unit,
            audio.kAudioUnitProperty_SetRenderCallback,
            audio.kAudioUnitScope_Input, 0,
            cb, #cb
        )
        if err != 0 {
            AudioComponentInstanceDispose(__unit)
            throw RuntimeError("AudioUnitSetProperty (RenderCallback) failed: {err}")
        }

        err = AudioUnitInitialize(__unit)
        if err != 0 {
            AudioComponentInstanceDispose(__unit)
            throw RuntimeError("AudioUnitInitialize failed: {err}")
        }
    }

    start!() {
        if !__running {
            let err = AudioOutputUnitStart(__unit)
            if err != 0 {
                throw RuntimeError("AudioOutputUnitStart failed: {err}")
            }
            __running = true
        }
        self
    }

    stop!() {
        if __running {
            AudioOutputUnitStop(__unit)
            __running = false
        }
        self
    }

    running? -> Bool {
        __running
    }

    close() {
        if __unit != nil {
            AudioOutputUnitStop(__unit)
            AudioUnitUninitialize(__unit)
            AudioComponentInstanceDispose(__unit)
            __unit = nil
            __running = false
        }
    }

    __drop__() { close() }
    __free__() { close() }
}
