pub tag Exit;
pub tag Wake;

use InkEventInternal = Exit | Wake | event.Event

let _event-queue: SharedQueue[InkEventInternal] = SharedQueue()
let _tio = nil

pub tag CycleCompletions, ListCompletions, Insert, ReplaceLine;

use StyledText = String | chalk::Text

pub use CompletionLabel = StyledText | Array[StyledText | nil]
pub use CompletionItem = String | (CompletionLabel, String)
pub use CompletionAction = CycleCompletions[Array[CompletionItem]]
                         | ListCompletions[Array[CompletionItem]]
                         | Insert[String]
                         | ReplaceLine[String]
                         | None
pub use CompletionFunction = {before: String, after: String} -> CompletionAction

fn completion-label(item: CompletionItem) -> CompletionLabel {
    (item :: String) ? item : item.0
}

fn completion-text(item: CompletionItem) -> String {
    match item {
        (_, s) => s,
        s      => s
    }
}

fn fit-items(items: Array[CompletionLabel], W: Int) -> Array[Array[String]] {
    fn width(text: StyledText | nil) -> Int {
        (text == nil) ? 0 : "{text}".width()
    }

    fn group-cols(n: Int) -> Array[Array[CompletionLabel]] {
        items.groups-of((#items + n - 1) / n)
    }

    fn widths(ncol: Int) -> Array[Array[Int]] {
        let cols = group-cols(ncol)

        fn col-widths(i: Int) -> Array[Int] {
            if i >= #cols { return [] }

            let nparts = cols[i]
                .map(label -> (label :: Array) ? #label : 1)
                .max()

            let parts: Array[Int] = []

            fn limit() -> Int {
                W - (parts.sum() ?? 0)
            }

            let max-singleton = 0

            for j in ..nparts {
                let w = cols[i].map(match {
                    (label: Array[StyledText | nil]) and (#label > j) =>
                        min(limit(), width(label[j])),
                    label and (j == 0) => do {
                        max-singleton = max(
                            max-singleton,
                            min(limit(), width(label))
                        )
                        0
                    },
                    _ => 0
                }).max() 
                parts.push(w || max-singleton ?? 0)
            }

            parts
        }

        [col-widths(it) for ..ncol]
    }

    let (ncol, ws) = (
        for ncol in 1..#items {
            let ws = widths(ncol + 1)
            if ws.flat().sum(0) + 6 * ncol > W {
                break (ncol, widths(ncol))
            }
        }
    ) ?? (#items, widths(#items))

    let cols: Array[Array[CompletionLabel]] = group-cols(ncol)
    let nrow: Int = cols.map(s -> #s).max() ?? 0

    fn s(x: StyledText | nil) -> String {
        match x {
            x: String => x,
            nil       => '',
            _         => "{x}"
        }
    }

    fn format(label: CompletionLabel, widths: Array[Int]) -> String {
        match label {
            parts: Array[StyledText | nil] => [
                "{s(parts[i]):<{widths[i]}}"
                for i in ..#parts
            ].str() ?? '',
            part => "{s(part):<{widths.sum()}}"
        }
    }

    return [
        cols.map(c -> (#c > i) ? c[i] : '').zip(ws, f=format)
        for i in ..nrow
    ]
}

