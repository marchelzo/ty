if not let $lib = c.dlopen('/System/Library/Frameworks/Accelerate.framework/Accelerate')
              ?? c.open(['BLAS', 'blas', 'openblas']) {
    throw RuntimeError('np: failed to load Accelerate/BLAS')
}

if not let $lapack = c.dlopen('/System/Library/Frameworks/Accelerate.framework/Accelerate')
                  ?? c.open(['LAPACK', 'lapack']) {
    throw RuntimeError('np: failed to load LAPACK')
}
#|else
if not let $lib = c.open(['BLAS', 'blas', 'openblas']) {
    throw RuntimeError('np: failed to load BLAS')
}

if not let $lapack = c.open(['LAPACK', 'lapack']) {
    throw RuntimeError('np: failed to load LAPACK')
}
