import chalk (chalk)
import os
import time
import ty (tests)

fn duration(dt: Float) {
    (dt < 1.0) ? "{dt * 1000.0:.2}ms" : "{dt:.2}s"
}

pub fn run() {
    let pass = 0
    let fail = 0

    let width = 1 + (tests.map(\#_.__name__).max() ?? 0)

    eprint("Running {#tests} tests...\n\n")

    for test in tests {
        print("{test.__name__:{width}} ... ", end='', flush=true)
        try {
            let t0 = time.now()
            test()
            print(chalk"[bright green b]OK[/] [bright magenta]({duration(time.now() - t0)})[/]")
            pass += 1
        } catch err {
            print(chalk"[bright red b]FAIL[/]\n\n{err}\n")
            if err :: RuntimeError {
                eprint(str(err.trace()))
            }
            fail += 1
        }
    }

    let failed = fail ?: chalk"[bright red b]{fail} failed[/]"
    let passed = pass ?: chalk"[bright green b]{pass} passed[/]"
    let result = [?failed, ?passed].join(', ')
    let _tests = (#tests == 1) ? 'test' : 'tests'

    print(chalk"\nRan [bright yellow b]{#tests}[/] {_tests}: {result}")

    (fail == 0) ? 0 : 1
}
