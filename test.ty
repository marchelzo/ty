import chalk (..)
import ffi as c (C!)
import os (..)
import path (Path)
import sh (sh)
import time
import tp (ThreadPool)
import ty

let TERM_COLS = match terminal-size() {
    {cols, *} => cols,
    else      => 80
}

let t0 = time.now()

let pass  = Sync(0)
let fail  = Sync(0)
let slow  = Sync(0)

fn +[T, U, V](x: Sync[T], y: Sync[U]) -> V where (T + U): V {
    Sync.read(x) + Sync.read(y)
}

let g = chalk['bold green']
let r = chalk['bold red']
let m = chalk['bold bright magenta']
let b = chalk['blue']

const TY_CMD  = getenv('TY_PATH') ?? ty.executable
const TY_OPTS = ['-q' if ty.q, '-j' if !ty.jit].unwords()

fn show-time(dt: Float) {
    match int(dt * 1000) {
        0..100 as ms => chalk"[#5f6b57]({ms}ms)[/]",
        100..200     => chalk"[#5f6b57]({dt:.2}s)[/]",
        200..500     => chalk"[#8d7e49]({dt:.2}s)[/]",
        else         => chalk"[#9c5645]({dt:.2}s)[/]",
    }
}

fn run(p: Path) {
    let t0 = time.now()

    let _, res = sh("{TY_CMD} --test {TY_OPTS} {p}", timeoutMs=5000)

    let (color, result) = match res {
        nil => do {
            slow += 1
            ('', m('TIMEOUT'))
        },

        {status: 0, signal: nil, *} => do {
            pass += 1
            let dt = show-time(time.now() - t0)
            ('#6b6862', chalk"[bright green bold]PASS[/] {dt}")
        },

        else => do {
            fail += 1
            let report = [
                r('FAIL'),
                m("  (exit status: {res.status})") if res.status != 0,
                b("  ({c.as_str(strsignal(res.signal))})") if res.signal != nil,
                chalk"\n[magenta]================ [yellow]STDOUT[/] ====================================[/]\n",
                res.stdout,
                r('~~~~~'),
                chalk"\n[magenta]================ [yellow]STDERR[/] ====================================[/]\n",
                res.stderr,
                r('~~~~~'),
                chalk"\n[magenta]============================================================[/]\n",
            ].join()
            ('#c53535', report)
        }
    }

    print("{chalk"[{color}]{p.stem:24}[/] [#444]...[/]"} {result}")
}

let pool = ThreadPool(ncpu(), run)

for (dir, _, files) in Path('tests').walk() {
    let full-cols = min(TERM_COLS, 64)
    let name-cols = "{dir}".width()
    let heading = '─' * (full-cols - name-cols - 4)
    print(chalk"[#555]──[/] [#4484d6]{dir}[/] [#555]{heading}[/]")
    let jobs = [pool.submit(dir / it) for files]
    for jobs {
        it.wait()
    }
}

print()

let elapsed = time.now() - t0

if pass > 0 {
    print("{g('Passed')}: {g(pass)}")
}

if fail > 0 {
    print("{r('Failed')}: {r(fail)}")
}

if slow > 0 {
    print("{m('Timed out')}: {m(slow)}")
}

print()
print("{b('Elapsed')}: {b("{elapsed:.4}s")}")

exit(fail + slow)
