ns test

pub fn arr() {
    let x = []
    assert(x.len() == 0 && #x == 0)
    match x {
     [] => ;,
     _  => assert(false)
    }
    x.push(1)
    x.push(2)
    assert(x.len() == 2)
    x.map!((+5))
    assert(x == [6, 7])
    assert(x.sum() == 13)
    x.splice(0)
    assert(#x == 0)
    let a = try x[4] else {
        return
    }
    assert(false)
}
