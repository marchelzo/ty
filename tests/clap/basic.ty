import clap (clap!)
import os

clap! Args {
    verbose: Bool, short: 'v', long: 'verbose'
    output: String, short: 'o', long: 'output', required: true
    debug: Bool, short: 'd', long: 'debug', count: true
    include: [String], short: 'I', long: 'include', repeat: true
    files: [String], pos: true, repeat: true, min: 1
}

fn forked(f) {
    let (r, w) = os.pipe()
    let pid = os.fork()

    if pid == 0 {
        os.close(r)
        os.dup2(w, 2)
        os.close(w)
        f()
        os.exit(0)
    }

    os.close(w)
    let err = os.read(r, 4096).str!()
    os.close(r)
    let (_, status) = os.wait(pid)!
    ((status >> 8) & 0xFF, err)
}

ns test

pub fn clap-basic() {
    let (code, err) = forked(fn () {
        let argv = ['prog', '-v', '-dd', '-I', 'inc1', '-Iinc2', '--output', 'out.txt', 'a', 'b']
        let (opts, rest) = Args.parse(argv)
        assert(opts.verbose == true)
        assert(opts.debug == 2)
        assert(opts.output == 'out.txt')
        assert(opts.include == ['inc1', 'inc2'])
        assert(opts.files == ['a', 'b'])
        assert(#rest == 0)
    })
    assert(code == 0, "exit {code}: {err}")
}
