import clap (clap!)
import os

clap! Init {
    name: String, pos: true, required: true
    force: Bool, short: 'f', long: 'force'
}

clap! Args {
    output: String, short: 'o', long: 'output', required: true
    cmd init: Init
}

fn forked(f) {
    let (r, w) = os.pipe()
    let pid = os.fork()

    if pid == 0 {
        os.close(r)
        os.dup2(w, 2)
        os.close(w)
        f()
        os.exit(0)
    }

    os.close(w)
    let err = os.read(r, 4096).str!()
    os.close(r)
    let (_, status) = os.wait(pid)!
    ((status >> 8) & 0xFF, err)
}

ns test

pub fn clap-subcommand() {
    let (code, err) = forked(fn () {
        let argv = ['prog', '--output', 'out.txt', 'init', '-f', 'proj']
        let (opts, rest) = Args.parse(argv)
        assert(opts.cmd :: Init)
        assert(opts.cmd.force == true)
        assert(opts.cmd.name == 'proj')
        assert(opts.output == 'out.txt')
        assert(#rest == 0)
    })
    assert(code == 0, "exit {code}: {err}")
}
