ns test

let n = 0

let drops = 0

class A {
    __drop__() {
        drops += 1
    }
}

class B {
    __drop__() {
        n += 1
    }
}

pub fn continue-continue() {
    n = 0
    drops = 0
    for i in ..5 {
        let ^b = B()
        break if i == 1
        for j in ..5 {
            let ^a = A()
            continue continue
        }
    }
    assert(n == 2)
    assert(drops > 0)
}
