ns test

pub fn ctor() {
    class Foo {
        x: Int = 0
        init(val: Int) {
            self.x = val * 2
        }
    }
    assert(Foo(val=5).x == 10)
    class Config {
        debug: Bool = false
        verbose: Bool = false
    }
    let c = Config(debug=true)
    assert(c.debug == true && c.verbose == false)
    assert(Config().debug == false)
    class Strict {
        count: Int
        name: String
    }
    let s = Strict(count=42, name='hello')
    assert(s.count == 42 && s.name == 'hello')
    class WithPrivate {
        _secret: Int = 0
        name: String = 'default'
    }
    assert(WithPrivate(name='test').name == 'test')
    class Base {
        x: Int = 0
    }
    class Child < Base {
        y: Int = 0
    }
    let ch = Child(x=10, y=20)
    assert(ch.x == 10 && ch.y == 20)
}
