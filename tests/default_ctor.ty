ns test

class Foo {
    x: Int = 0
    init(val: Int) {
        self.x = val * 2
    }
}

class Config {
    debug: Bool = false
    verbose: Bool = false
}

class Strict {
    count: Int
    name: String
}

class WithPrivate {
    _secret: Int = 0
    name: String = 'default'
}

class Base {
    x: Int = 0
}

class Child < Base {
    y: Int = 0
}

pub fn ctor() {
    assert(Foo(val=5).x == 10)
    let c = Config(debug=true)
    assert(c.debug == true)
    assert(c.verbose == false)
    assert(Config().debug == false)
    let s = Strict(count=42, name='hello')
    assert(s.count == 42)
    assert(s.name == 'hello')
    assert(WithPrivate(name='test').name == 'test')
    let ch = Child(x=10, y=20)
    assert(ch.x == 10)
    assert(ch.y == 20)
}
