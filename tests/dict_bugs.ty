ns test

pub fn test-dict-clear-tombs() {
    let d = %{'a': 1, 'b': 2, 'c': 3, 'd': 4}
    d.remove('a')
    d.remove('b')
    d.clear()
    d['x'] = 10
    d['y'] = 20
    assert(d['x'] == 10)
    assert(d['y'] == 20)
    assert(#d == 2)
}

pub fn test-dict-intersect-copy() {
    let d1 = %{'a': 1, 'b': 2, 'c': 3}
    let d2 = %{'b': 20, 'c': 30, 'd': 40}
    let r = d1 & d2
    assert(r.has?('b'))
    assert(r.has?('c'))
    assert(!r.has?('a'))
    assert(!r.has?('d'))
    assert(d1.has?('a'))
}

pub fn test-dict-keep-mut() {
    let d = %{'a': 1, 'b': 2, 'c': 3, 'd': 4}
    d.keep!((k, v) -> v > 2)
    assert(#d == 2)
    assert(d.has?('c'))
    assert(d.has?('d'))
    assert(!d.has?('a'))
    assert(!d.has?('b'))
}

pub fn test-dict-update-with() {
    let d = %{'a': 1, 'b': 2}
    let u = %{'b': 10, 'c': 30}
    d.update(u, (a, b) -> a + b)
    assert(d['a'] == 1)
    assert(d['b'] == 12)
    assert(d['c'] == 30)
}

pub fn test-dict-subtract-callback() {
    let d = %{'a': 100, 'b': 200, 'c': 300}
    let u = %{'a': 1, 'b': 2}
    let xs = []
    d.subtract(u, (sv, ov) -> xs.push("{sv},{ov}"))
    assert(!d.has?('a'))
    assert(!d.has?('b'))
    assert(d.has?('c') && d['c'] == 300)
    let fa = false
    let fb = false
    for x in xs {
        if x == '100,1' { fa = true }
        if x == '200,2' { fb = true }
    }
    assert(fa)
    assert(fb)
}
