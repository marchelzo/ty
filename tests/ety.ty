import ety

ns test

pub fn template() {
    let tmpl = ety.compile(
        '''
        ### This is a template string.
        #### You have <%= #widgets %> widgets:
        <% for w in widgets { %>
        - Widget: <%= w.name %>
        <% } %>
        '''
    )
    let widgets = [
        { name: 'Widget A' },
        { name: 'Widget B' },
        { name: 'Widget C' }
    ]
    let output = tmpl(widgets)
    let expected =
        '''
        ### This is a template string.
        #### You have 3 widgets:
        - Widget: Widget A
        - Widget: Widget B
        - Widget: Widget C

        '''
    assert(output == expected)
}
