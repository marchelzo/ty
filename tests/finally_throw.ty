ns test

pub fn finally-throw() {
    let s = '''
        try {
            try {
                throw 20
            } catch _ {
            } finally {
                throw 50
            }
        } catch _ {
            "PASS"
        }
    '''
    let r = try {
        __eval__(s)
    } catch Err(e) {
        e
    }
    assert(r == 'PASS')
}
