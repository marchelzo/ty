ns test

pub fn if-let-guard() {
    if let Some(x) = Some(10) and x > 20 {
        assert(false)
    }
}

pub fn nested-if-let() {
    if let Some(x) = Some(Ok(3)) and let Ok(y) = x {
        ;
    } else {
        assert(false)
    }
}

pub fn not-let-empty() {
    if not let [x] = [] {
        ;
    } else {
        assert(false)
    }
}

pub fn not-let-tuple() {
    if not let (a, b) = (4, 5) or a != b {
        ;
    } else {
        assert(false)
    }
}

pub fn not-let-double-neg() {
    if not let (a, b) = (4, 5) or not a != b {
        assert(false)
    }
}

pub fn try-assign() {
    let [x] = [] or {
        ;
    }
    assert(x == nil)
    fn g() {
        throw 100
    }
    try [x] = [g()] else return
    assert(false)
}
