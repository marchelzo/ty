import ink
import term
use term

ns test

class Probe < ink.Component {
    focusable? -> Bool { true }
    on-event(ev) {}
    render() { <ink.Text>P</ink.Text> }
}

fn probe-pos(h) -> (Int, Int) {
    let $p = h.find(Probe) or throw 'no Probe'
    (p.layout-x, p.layout-y)
}

class ColStackApp < ink.Component {
    render() {
        <ink.Box direction="column" width=20>
            <ink.Text>aaa</ink.Text>
            <ink.Text>bbb</ink.Text>
            <Probe />
        </ink.Box>
    }
}

pub fn column-stacking() {
    let h = ink.TestHarness(ColStackApp(), cols=20, rows=10)
    assert(probe-pos(h) == (0, 2))
}

class RowStackApp < ink.Component {
    render() {
        <ink.Box direction="row" width=20>
            <ink.Box width=5><ink.Text>aaa</ink.Text></ink.Box>
            <ink.Box width=5><ink.Text>bbb</ink.Text></ink.Box>
            <Probe />
        </ink.Box>
    }
}

pub fn row-stacking() {
    let h = ink.TestHarness(RowStackApp(), cols=20, rows=10)
    let (px, py) = probe-pos(h)
    assert(px == 10 && py == 0)
}

