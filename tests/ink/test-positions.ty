}

pub fn justify-end-row() {
    let h = ink.TestHarness(JEndRowApp(), cols=20, rows=10)
    let (px, py) = probe-pos(h)
    assert(px == 19)
}

class ProbeA < ink.Component {
    focusable? -> Bool { true }
    render() { <ink.Text>A</ink.Text> }
}

class ProbeB < ink.Component {
    focusable? -> Bool { true }
    render() { <ink.Text>B</ink.Text> }
}

class JSpaceBetweenApp < ink.Component {
    render() {
        <ink.Box direction="row" justify="space-between" width=20>
            <ProbeA />
            <ProbeB />
        </ink.Box>
    }
}

pub fn justify-space-between-row() {
    let h = ink.TestHarness(JSpaceBetweenApp(), cols=20, rows=10)
    let $a = h.find(ProbeA) or throw 'no A'
    let $b = h.find(ProbeB) or throw 'no B'
    assert(a.layout-x == 0)
    assert(b.layout-x == 19)
}

