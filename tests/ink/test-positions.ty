class NestPadApp < ink.Component {
    render() {
        <ink.Box pad-x=2 pad-y=1 width=30>
            <ink.Box pad-x=3 pad-y=2>
                <Probe />
            </ink.Box>
        </ink.Box>
    }
}

pub fn nested-offsets-accumulate() {
    let h = ink.TestHarness(NestPadApp(), cols=30, rows=15)
    assert(probe-pos(h) == (5, 3))
}

class JCenterColApp < ink.Component {
    render() {
        <ink.Box direction="column" justify="center" width=20 height=10>
            <Probe />
        </ink.Box>
    }
}

pub fn justify-center-column() {
    let h = ink.TestHarness(JCenterColApp(), cols=20, rows=10)
    let (px, py) = probe-pos(h)
    assert(px == 0)
    assert(py >= 4 && py <= 5)
}

