}

pub fn justify-end-column() {
    let h = ink.TestHarness(JEndColApp(), cols=20, rows=10)
    let (px, py) = probe-pos(h)
    assert(py == 9)
}

class JCenterRowApp < ink.Component {
    render() {
        <ink.Box direction="row" justify="center" width=20>
            <Probe />
        </ink.Box>
    }
}

pub fn justify-center-row() {
    let h = ink.TestHarness(JCenterRowApp(), cols=20, rows=10)
    let (px, py) = probe-pos(h)
    assert(py == 0)
    assert(px >= 9 && px <= 10)
