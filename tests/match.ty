ns test

pub fn matchtest() {
    match [3, ('foo', 'bar'), {a: 1, b: 2, c: 3}, 9, 9, 9] {
        [a, b, {a: 2}, *_] => { assert(false) },
        [x, ('foo', _), {a, b, c, ?d}, *rest] => {
            assert(x == 3)
            assert(a == 1)
            assert(b == 2)
            assert(c == 3)
            assert(rest.sum() == 27)
        },
        _ => assert(false)
    }
    match Ok(10) {
        Ok(x), [x, y, z] => {
            assert((x, y, z) == (10, nil, nil))
        }
    }
}
