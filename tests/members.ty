ns test

pub fn test-members() {
    let x: _ = 10
    assert(members(x) == nil)
    let y: _ = 'asd'
    assert(members(y) == nil)
    assert(members({a: 5, b: 10})['a'] == 5)
    assert(members({foo: 123, bar: 456}).keys().sort() == ['bar', 'foo'])
    assert(members((4, 5, 6)).keys().sort() == [0, 1, 2])
}
