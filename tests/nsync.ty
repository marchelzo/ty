import os (sleep, ncpu)
import thread
import tp (..)

ns test

pub fn test-mutex-lock-unlock() {
    let mtx = Mutex()
    mtx.lock()
    mtx.unlock()
}

pub fn test-mutex-trylock() {
    let mtx = Mutex()
    assert(mtx.tryLock() != nil)
    mtx.unlock()
}

pub fn test-mutex-with-block() {
    let mtx = Mutex()
    let x = 0
    with mtx {
        x = 42
    }
    assert(x == 42)
}

pub fn test-mutex-protects-data() {
    let mtx = Mutex()
    let count = 0
    let N = 100
    fn go() {
        for ..N {
            with mtx {
                count += 1
            }
        }
    }
    let threads = [Thread(go) for ..4]
    for threads { it.join() }
    assert(count == 4 * N)
}

pub fn test-condvar-signal() {
    let mtx = Mutex()
    let cv = CondVar()
    let ready = false
    let t = Thread(function () {
        with mtx {
            ready = true
        }
        cv.signal()
    })
    mtx.lock()
    while !ready {
        cv.wait(mtx)
    }
    assert(ready)
    mtx.unlock()
    t.join()
}

pub fn test-condvar-broadcast() {
    let mtx = Mutex()
    let cv = CondVar()
    let go = false
    let arrived = 0
    let N = 4
    let threads = [Thread(function () {
        mtx.lock()
        arrived += 1
        while !go {
            cv.wait(mtx)
        }
        mtx.unlock()
    }) for _ in ..N]
    for (;;) {
        with mtx {
            break if arrived == N
        }
        sleep(0.001)
    }
    with mtx { go = true }
    cv.broadcast()
    for t in threads { t.join() }
    assert(arrived == N)
}

pub fn test-condvar-timed-wait() {
    let mtx = Mutex()
    let cv = CondVar()
    mtx.lock()
    let ok = cv.wait(mtx, 0.01)
    assert(!ok)
    mtx.unlock()
}

pub fn test-shared-queue-single-thread() {
    let q = SharedQueue()
    q.put(1)
    q.put(2)
    q.put(3)
    assert(q.take() == 1)
    assert(q.take() == 2)
    assert(q.take() == 3)
}

pub fn test-shared-queue-multi-thread() {
    let q = SharedQueue()
    let N = 50
    let producers = [Thread(function () {
        for j in ..N {
            q.put(i * N + j)
        }
    }) for i in ..4]
    let results = Sync([])
    let consumers = [Thread(function () {
        for _ in ..2*N {
            results.push(q.take())
        }
    }) for _ in ..2]
    for t in producers  { t.join() }
    for t in consumers  { t.join() }
    let got = results.sort()
    let expected = [i for i in 0..4*N]
    assert(#got == #expected)
    assert(got == expected)
}

pub fn test-shared-queue-try-take() {
    let q = SharedQueue()
    assert(q.try-take() == None)
    q.put(42)
    assert(q.try-take() == Some(42))
    assert(q.try-take() == None)
}

pub fn test-thread-pool-basic() {
    let pool = ThreadPool(2, function (x) { x * 2 })
    let futures = [pool.submit(i) for i in 1..5]
    let results: Array[Int] = [f.wait() for f in futures]
    assert(results.sort() == [2, 4, 6, 8])
    pool.close()
}

pub fn test-thread-pool-many-tasks() {
    let N = 20
    let pool = ThreadPool(4, function (x) { x + 1 })
    let futures = [pool.submit(i) for i in 0..N]
    let results: Array[Int] = [f.wait() for f in futures]
    assert(results.sort() == [i for i in 1..N+1])
    pool.close()
}

pub fn test-future-cancel() {
    let pool = ThreadPool(1, function (x) {
        sleep(0.02)
        x
    })
    let f1 = pool.submit(1)
    let f2 = pool.submit(2)
    let canceled = f2.cancel()
    pool.close()
    assert(canceled)
    assert(f2.canceled?)
}

pub fn test-note-create-and-query() {
    let n = thread.note()
    assert(!thread.notified?(n))
    thread.notify(n)
    assert(thread.notified?(n))
    thread.destroy(n)
}

pub fn test-note-notify-is-idempotent() {
    let n = thread.note()
    thread.notify(n)
    thread.notify(n)
    assert(thread.notified?(n))
    thread.destroy(n)
}

pub fn test-note-wait-already-notified() {
    let n = thread.note()
    thread.notify(n)
    assert(thread.wait-note(n, 100))
    thread.destroy(n)
}

pub fn test-note-wait-timeout() {
    let n = thread.note()
    assert(!thread.wait-note(n, 10))
    thread.destroy(n)
}

pub fn test-note-cross-thread() {
    let n = thread.note()
    let t = Thread(function () {
        sleep(0.001)
        thread.notify(n)
    })
    assert(thread.wait-note(n, 2000))
    assert(thread.notified?(n))
    t.join()
    thread.destroy(n)
}

pub fn test-note-multiple-waiters() {
    let n = thread.note()
    let threads = [Thread(function () {
        thread.wait-note(n, 2000)
    }) for _ in ..4]
    sleep(0.001)
    thread.notify(n)
    for t in threads { t.join() }
    assert(thread.notified?(n))
    thread.destroy(n)
}

pub fn test-counter-create-and-query() {
    let c = thread.counter(5)
    assert(thread.countValue(c) == 5)
    thread.destroy(c)
}

pub fn test-counter-add() {
    let c = thread.counter(10)
    assert(thread.count-add(c, -3) == 7)
    assert(thread.countValue(c) == 7)
    assert(thread.count-add(c, -7) == 0)
    assert(thread.countValue(c) == 0)
    thread.destroy(c)
}

pub fn test-counter-wait-already-zero() {
    let c = thread.counter(0)
    let v = thread.count-wait(c, 100)
    assert(v == 0)
    thread.destroy(c)
}

pub fn test-counter-wait-timeout() {
    let c = thread.counter(1)
    let v = thread.count-wait(c, 10)
    assert(v != 0)
    thread.destroy(c)
}

pub fn test-counter-wait-cross-thread() {
    let N = 4
    let c = thread.counter(N)
    let threads = [Thread(function () {
        sleep(0.001)
        thread.count-add(c, -1)
    }) for _ in ..N]
    let v = thread.count-wait(c, 2000)
    assert(v == 0)
    for t in threads { t.join() }
    thread.destroy(c)
}

pub fn test-counter-as-join-barrier() {
    let c = thread.counter(3)
    let results = Sync([])
    let threads = [Thread(function () {
        results.push(i)
        thread.count-add(c, -1)
    }) for i in ..3]
    let v = thread.count-wait(c, 2000)
    assert(v == 0)
    assert(#results == 3)
    for t in threads { t.join() }
    thread.destroy(c)
}

pub fn test-wait-any-single-note-notified() {
    let n = thread.note()
    thread.notify(n)
    let idx = thread.wait-any([n], 100)
    assert(idx == 0)
    thread.destroy(n)
}

pub fn test-wait-any-timeout() {
    let n1 = thread.note()
    let n2 = thread.note()
    let idx = thread.wait-any([n1, n2], 10)
    assert(idx == 2)
    thread.destroy(n1)
    thread.destroy(n2)
}

pub fn test-wait-any-second-note() {
    let n1 = thread.note()
    let n2 = thread.note()
    thread.notify(n2)
    let idx = thread.wait-any([n1, n2], 100)
    assert(idx == 1)
    thread.destroy(n1)
    thread.destroy(n2)
}

pub fn test-wait-any-counter-at-zero() {
    let c = thread.counter(0)
    let idx = thread.wait-any([c], 100)
    assert(idx == 0)
    thread.destroy(c)
}

pub fn test-wait-any-mixed-types() {
    let n = thread.note()
    let c = thread.counter(0)
    let idx = thread.wait-any([n, c], 100)
    assert(idx == 1)
    thread.destroy(n)
    thread.destroy(c)
