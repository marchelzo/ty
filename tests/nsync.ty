    let n1 = thread.note()
    let n2 = thread.note()
    thread.notify(n1)
    thread.notify(n2)
    let idx = thread.wait-any([n1, n2], 100)
    assert(idx == 0 || idx == 1)
    thread.destroy(n1)
    thread.destroy(n2)
}

pub fn test-wait-any-empty-array() {
    let idx = thread.wait-any([], 10)
    assert(idx == 0)
}

