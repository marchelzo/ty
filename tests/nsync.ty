pub fn test-wait-any-many-mixed() {
    let n1 = thread.note()
    let n2 = thread.note()
    let c1 = thread.counter(5)
    let c2 = thread.counter(1)
    let t = Thread(function () {
        sleep(0.001)
        thread.count-add(c2, -1)
    })
    let idx = thread.wait-any([n1, c1, n2, c2], 2000)
    assert(idx == 3)
    t.join()
    thread.destroy(n1)
    thread.destroy(n2)
    thread.destroy(c1)
    thread.destroy(c2)
}

pub fn test-wait-any-mixed-both-ready() {
    let n = thread.note()
    let c = thread.counter(0)
    thread.notify(n)
    let idx = thread.wait-any([n, c], 100)
    assert(idx == 0 || idx == 1)
    thread.destroy(n)
    thread.destroy(c)
}

pub fn test-wait-any-mixed-timeout() {
    let n = thread.note()
    let c = thread.counter(3)
    let idx = thread.wait-any([n, c], 10)
    assert(idx == 2)
    thread.destroy(n)
    thread.destroy(c)
}

pub fn test-wait-any-condvar-signaled() {
    let mu = thread.mutex()
    let cv = thread.cond()
    let ready = false
    let t = Thread(function () {
        sleep(0.001)
        thread.lock(mu)
        ready = true
        thread.unlock(mu)
        thread.signal-cond(cv)
    })
    thread.lock(mu)
    let idx = thread.wait-any([cv], 2000, mu)
    assert(idx == 0)
    assert(ready)
    thread.unlock(mu)
    t.join()
    thread.destroy(cv)
    thread.destroy(mu)
}

pub fn test-wait-any-condvar-vs-note() {
    let mu = thread.mutex()
    let cv = thread.cond()
    let n = thread.note()
    let t = Thread(function () {
        sleep(0.001)
        thread.notify(n)
    })
    thread.lock(mu)
    let idx = thread.wait-any([n, cv], 2000, mu)
    assert(idx == 0)
    thread.unlock(mu)
    t.join()
    thread.destroy(n)
    thread.destroy(cv)
    thread.destroy(mu)
}

pub fn test-wait-any-condvar-vs-counter() {
    let mu = thread.mutex()
    let cv = thread.cond()
    let c = thread.counter(1)
    let t = Thread(function () {
        sleep(0.001)
        thread.count-add(c, -1)
    })
    thread.lock(mu)
    let idx = thread.wait-any([cv, c], 2000, mu)
    assert(idx == 1)
    thread.unlock(mu)
    t.join()
    thread.destroy(cv)
    thread.destroy(mu)
    thread.destroy(c)
}

pub fn test-wait-any-condvar-fires-in-mixed() {
    let mu = thread.mutex()
    let cv = thread.cond()
    let n = thread.note()
    let c = thread.counter(5)
    let t = Thread(function () {
        sleep(0.001)
        thread.lock(mu)
        thread.unlock(mu)
        thread.signal-cond(cv)
    })
    thread.lock(mu)
    let idx = thread.wait-any([n, cv, c], 2000, mu)
    assert(idx == 1)
    thread.unlock(mu)
    t.join()
    thread.destroy(n)
    thread.destroy(cv)
    thread.destroy(mu)
    thread.destroy(c)
}

pub fn test-wait-any-two-condvars() {
    let mu = thread.mutex()
    let cv1 = thread.cond()
    let cv2 = thread.cond()
    let t = Thread(function () {
        sleep(0.001)
        thread.lock(mu)
        thread.unlock(mu)
        thread.signal-cond(cv2)
    })
    thread.lock(mu)
    let idx = thread.wait-any([cv1, cv2], 2000, mu)
    assert(idx == 1)
    thread.unlock(mu)
    t.join()
    thread.destroy(cv1)
    thread.destroy(cv2)
    thread.destroy(mu)
}

pub fn test-note-with-mutex-handoff() {
    let mtx = Mutex()
    let done = thread.note()
    let result = 0
    let t = Thread(function () {
        with mtx {
            result = 42
        }
        thread.notify(done)
    })
    thread.wait-note(done, 2000)
    with mtx {
        assert(result == 42)
    }
    t.join()
    thread.destroy(done)
}

pub fn test-counter-fan-out-fan-in() {
    let N = 8
    let c = thread.counter(N)
    let mtx = Mutex()
    let total = 0
    let threads = [Thread(function () {
        with mtx { total += i }
        thread.count-add(c, -1)
    }) for i in ..N]
    let v = thread.count-wait(c, 2000)
    assert(v == 0)
    with mtx {
        assert(total == N * (N - 1) / 2)
    }
    for t in threads { t.join() }
    thread.destroy(c)
}
