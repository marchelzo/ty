pub fn test-wait-any-cross-thread() {
    let n1 = thread.note()
    let n2 = thread.note()
    let t = Thread(function () {
        sleep(0.001)
        thread.notify(n2)
    })
    let idx = thread.wait-any([n1, n2], 2000)
