    let c = thread.counter(1)
    let n = thread.note()
    let t = Thread(function () {
        sleep(0.001)
        thread.notify(n)
    })
    let idx = thread.wait-any([n, c], 2000)
    assert(idx == 0)
    t.join()
    thread.destroy(n)
