    let c = thread.counter(1)
    let n = thread.note()
    let t = Thread(function () {
        sleep(0.001)
        thread.count-add(c, -1)
    })
    let idx = thread.wait-any([n, c], 2000)
    assert(idx == 1)
    t.join()
    thread.destroy(n)
    thread.destroy(c)
}

