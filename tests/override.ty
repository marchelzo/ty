ns test

class A {
    foo(x: Int) -> Int {
        x * 2
    }
    bar(x: Int) -> Int {
        x * 3
    }
}

class B < A {
    foo(msg: String) {
        super(msg.count('.'))
    }
    bar(x: Int) {
        x * 5
    }
}

pub fn override() {
    assert(B().bar(4) == 20)
    assert(B().foo('o.o') == 2)
}
