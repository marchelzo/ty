import path
import os
import ty.parse as parse

ns test

pub fn basic-construction() {
    let p = path.Path('foo/bar')
    assert(str(p) == 'foo/bar')
    let p2 = path.Path(p)
    assert(str(p2) == 'foo/bar')
    assert(p == p2)
    let empty = path.Path()
    assert(str(empty) == '.')
}

pub fn join() {
    let p = path.Path('foo')
    let p2 = p / 'bar'
    assert(str(p2) == 'foo/bar')
    let p3 = p2 / 'baz'
    assert(str(p3) == 'foo/bar/baz')
#|if !__windows__
    let p4 = p / '/absolute'
    assert(str(p4) == '/absolute')
#|]
}

pub fn parent() {
    let p = path.Path('foo/bar/baz')
    assert(str(p.parent) == 'foo/bar')
    assert(str(p.parent.parent) == 'foo')
    assert(str(p.parent.parent.parent) == '.')
    assert(str(p.parent.parent.parent.parent) == '.')
#|if !__windows__
    let abs = path.Path('/foo/bar')
    assert(str(abs.parent) == '/foo')
    assert(str(abs.parent.parent) == '/')
    assert(str(abs.parent.parent.parent) == '/')
#|]
}

pub fn name-stem-suffix() {
    let p = path.Path('foo/bar.txt')
    assert(p.name == 'bar.txt')
    assert(p.stem == 'bar')
    assert(p.suffix == '.txt')
    let p2 = path.Path('foo/archive.tar.gz')
    assert(p2.name == 'archive.tar.gz')
    assert(p2.stem == 'archive.tar')
    assert(p2.suffix == '.gz')
    assert(p2.suffixes == ['.tar', '.gz'])
    let noext = path.Path('foo/bar')
    assert(noext.stem == 'bar')
    assert(noext.suffix == '')
    assert(#noext.suffixes == 0)
    let hidden = path.Path('.bashrc')
    assert(hidden.name == '.bashrc')
    assert(hidden.stem == '.bashrc')
    assert(hidden.suffix == '')
}

pub fn with-name() {
    let p = path.Path('foo/bar.txt')
    let p2 = p.with-name('baz.py')
    assert(str(p2) == 'foo/baz.py')
    let p3 = p.with-stem('qux')
    assert(str(p3) == 'foo/qux.txt')
    let p4 = p.with-suffix('.md')
    assert(str(p4) == 'foo/bar.md')
    let p5 = p.with-suffix('')
    assert(str(p5) == 'foo/bar')
}

pub fn parts() {
    let p = path.Path('foo/bar/baz')
    assert(p.parts == ['foo', 'bar', 'baz'])
#|if !__windows__
    let abs = path.Path('/foo/bar')
    assert(abs.parts == ['/', 'foo', 'bar'])
    let root = path.Path('/')
    assert(root.parts == ['/'])
#|else
    let abs = path.Path('C:\\foo\\bar')
    assert(abs.parts == ['C:\\', 'foo', 'bar'])
#|]
}

pub fn absolute() {
    let rel = path.Path('foo/bar')
    assert(!rel.absolute?)
#|if !__windows__
    let abs = path.Path('/foo/bar')
    assert(abs.absolute?)
    let root = path.Path('/')
    assert(root.absolute?)
#|else
    let abs = path.Path('C:\\foo\\bar')
    assert(abs.absolute?)
    let unc = path.Path('\\\\server\\share\\file')
    assert(unc.absolute?)
#|]
}

pub fn anchor() {
    let rel = path.Path('foo/bar')
    assert(rel.anchor == '')
#|if !__windows__
    let abs = path.Path('/foo/bar')
    assert(abs.anchor == '/')
#|else
    let abs = path.Path('C:\\foo\\bar')
    assert(abs.anchor == 'C:\\')
#|]
}

pub fn normalize-dots() {
    let p = path.Path('foo/./bar')
    assert(str(p) == 'foo/bar')
    let p2 = path.Path('foo/bar/.')
    assert(str(p2) == 'foo/bar')
    let p3 = path.Path('./foo')
    assert(str(p3) == 'foo')
}

pub fn equality() {
    let p1 = path.Path('foo/bar')
    let p2 = path.Path('foo/bar')
    let p3 = path.Path('foo/baz')
    assert(p1 == p2)
    assert(p1 != p3)
    assert(p1 == 'foo/bar')
}

pub fn hash-test() {
    let p1 = path.Path('foo/bar')
    let p2 = path.Path('foo/bar')
    let p3 = path.Path('foo/baz')
    assert(hash(p1) == hash(p2))
    assert(hash(p1) != hash(p3))
    let d = %{p1: 'value1', p3: 'value2'}
    assert(d[p2] == 'value1')
}

pub fn file-operations() {
    let tmp = path.Path("/tmp/ty-path-test-{rand()}")
    tmp.mkdir(parents=true, exist-ok=true)
    assert(tmp.exists?)
    assert(tmp.dir?)
    let file = tmp / 'test.txt'
    file.write('hello world')
    assert(file.exists?)
    assert(file.file?)
    let content = file.read-text()
    assert(content == 'hello world')
    let bf = tmp / 'test.bin'
    bf.write(Blob(1, 2, 3, 4))
    let data = bf.read-bytes()
    assert(#data == 4)
    let renamed = tmp / 'renamed.txt'
    file.rename(renamed)
    assert(!file.exists?)
    assert(renamed.exists?)
    let touched = tmp / 'touched.txt'
    touched.touch()
    assert(touched.exists?)
    for entry in tmp.ls() {
        entry.unlink()
    }
    tmp.rmdir()
    assert(!tmp.exists?)
}

pub fn ls() {
    let tmp = path.Path("/tmp/ty-path-ls-{rand()}")
    tmp.mkdir()
    (tmp / 'file1.txt').touch()
    (tmp / 'file2.txt').touch()
    (tmp / 'subdir').mkdir()
    let entries = tmp.ls()
    assert(#entries == 3)
    let names = entries.map(\_.name).sort()
    assert(names == ['file1.txt', 'file2.txt', 'subdir'])
    for entry in tmp.ls() {
        if entry.dir? {
            entry.rmdir()
        } else {
            entry.unlink()
        }
    }
    tmp.rmdir()
}

pub fn glob-test() {
    let tmp = path.Path("/tmp/ty-path-glob-{rand()}")
    tmp.mkdir()
    (tmp / 'file1.txt').touch()
    (tmp / 'file2.txt').touch()
    (tmp / 'file3.py').touch()
    (tmp / 'subdir').mkdir()
    (tmp / 'subdir' / 'nested.txt').touch()
    let tf = tmp.glob('*.txt').map(\_.name).sort()
    assert(tf == ['file1.txt', 'file2.txt'])
    let f1 = tmp.glob('file?.txt').map(\_.name).sort()
    assert(#f1 == 2)
    let at = tmp.rglob('*.txt').map(\_.name).sort()
    assert(at == ['file1.txt', 'file2.txt', 'nested.txt'])
    (tmp / 'subdir' / 'nested.txt').unlink()
    (tmp / 'subdir').rmdir()
    for entry in tmp.ls() {
        entry.unlink()
    }
    tmp.rmdir()
}

pub fn walk-test() {
    let tmp = path.Path("/tmp/ty-path-walk-{rand()}")
    tmp.mkdir()
    (tmp / 'file1.txt').touch()
    (tmp / 'dir1').mkdir()
    (tmp / 'dir1' / 'file2.txt').touch()
    (tmp / 'dir1' / 'dir2').mkdir()
    (tmp / 'dir1' / 'dir2' / 'file3.txt').touch()
    let ap = []
    for (dir, dirs, files) in tmp.walk() {
        ap.push(str(dir))
    }
    assert(#ap >= 3)
    (tmp / 'dir1' / 'dir2' / 'file3.txt').unlink()
    (tmp / 'dir1' / 'dir2').rmdir()
    (tmp / 'dir1' / 'file2.txt').unlink()
    (tmp / 'dir1').rmdir()
    (tmp / 'file1.txt').unlink()
    tmp.rmdir()
}

pub fn cwd-home() {
    let cwd = path.cwd()
    assert(cwd.absolute?)
    assert(cwd.exists?)
    let home = path.home()
    assert(home.absolute?)
    assert(home.exists?)
}

pub fn chmod-test() {
    let tmp = path.Path("/tmp/ty-path-chmod-{rand()}")
    tmp.mkdir()
    (tmp / 'test.txt').touch()
    let file = tmp / 'test.txt'
    file.chmod(0o644)
    let st = file.stat
    assert((st.mode & 0o777) == 0o644)
    file.unlink()
    tmp.rmdir()
}

pub fn symlink-test() {
    let tmp = path.Path("/tmp/ty-path-symlink-{rand()}")
    tmp.mkdir()
    let tgt = tmp / 'target.txt'
    tgt.write('target content')
    let lnk = tmp / 'link.txt'
    os.symlink("{tgt}", "{lnk}")
    assert(lnk.exists?)
    assert(lnk.symlink?)
    assert(!tgt.symlink?)
    let resolved = lnk.readlink
    assert(resolved.name == 'target.txt')
    lnk.unlink()
    tgt.unlink()
    tmp.rmdir()
}

pub fn stat-test() {
    let tmp = path.Path("/tmp/ty-path-stat-{rand()}")
    tmp.mkdir()
    let file = tmp / 'test.txt'
    file.write('content')
    let st = file.stat
    assert(st.size :: Int)
    assert(st.mode :: Int)
    assert((st.mtime :: Int) || (st.mtime :: Float))
    file.unlink()
    tmp.rmdir()
}

pub fn edge-cases() {
    let empty = path.Path('')
    assert(str(empty) == '.')
    let trailing = path.Path('foo/bar/')
    assert(str(trailing) == 'foo/bar')
    let multi = path.Path('foo//bar///baz')
    assert(str(multi) == 'foo/bar/baz')
#|if !__windows__
    let root = path.Path('/')
    assert(str(root) == '/')
    assert(root.name == '')
#|]
}
