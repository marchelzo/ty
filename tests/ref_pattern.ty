ns test

pub fn ref-pattern() {
    let x = nil
    match [4, 5, 6] {
        [4, >x, -1] => { },
        [>x] => { },
        [_, _, >x, *] => { }
    }
    assert(x == 6)
    if not let Some([_, >x]) = Some([0, 1]) {
        assert(false)
    }
    assert(x == 1)
    let [_, _, >x] = [*'based']
    assert(x == 's')
}
