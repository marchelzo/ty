import sh (sh)

ns test

pub fn sh-basic() {
    if __windows__ {
        let $out = sh('echo hello')
        assert(out.strip() == 'hello')
    } else {
        let $out = sh('printf based')
        assert(out == 'based')
    }
}

pub fn sh-combine-output() {
    if not __windows__ {
        let $out = sh('printf based 1>&2', combineOutput=true)
        assert(out == 'based')
    }
}

pub fn sh-timeout() {
    if __windows__ {
        assert(sh('Sleep 1; echo Hello', shell: ['powershell', '-Command'], timeoutMs: 100) == nil)
    } else {
        assert(sh('sleep 0.25', timeoutMs=100) == nil)
    }
}
