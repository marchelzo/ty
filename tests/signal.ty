import os (..)

ns test

pub fn blocks-and-queries() {
    let blocked = Signals(SIGUSR1, SIGUSR2)
    let old = blocked.block()
    Thread.kill(SIGUSR1)
    assert(SIGUSR1 in Signals.pending, "SIGUSR1 should be pending after block")
    Signals.flush()
    old.set()
}

pub fn wait-retrieves-blocked() {
    let blocked = Signals(SIGUSR1)
    let old = blocked.block()
    Thread.kill(SIGUSR1)
    let sig = blocked.wait()
    assert(sig == SIGUSR1, "wait should return SIGUSR1")
    old.set()
}

pub fn handler-fires() {
    let fired = false
    signal(SIGUSR1, fn () {
        fired = true
    })
    Thread.kill(SIGUSR1)
    sleep(0.01)
    assert(fired, "signal handler should have executed")
    signal(SIGUSR1, SIG_DFL)
}

pub fn suspend-waits-unblocked() {
    Signals.block(SIGUSR2)
    match fork() {
        0 => {
            let received = false
            signal(SIGUSR2, fn () {
                received = true
            })
            Signals().suspend()
            assert(received, "suspend should wake on SIGUSR2")
            exit(0)
        },
        pid => {
            sleep(0.01)
            kill(pid, SIGUSR2)
            if let Some((_, st)) = wait() {
                assert(st == 0, "child should exit cleanly")
            }
        }
    }
}

pub fn restore-mask() {
    let orig = Signals.mask
    Signals.block(SIGUSR1)
    orig.set()
    let cur = Signals.mask
    assert(!cur.contains?(SIGUSR1), "mask should restore to original state")
}

pub fn kill-delivers-to-target() {
    match fork() {
        0 => {
            let caught = false
            signal(SIGUSR1, fn () {
                caught = true
            })
            sleep(0.15)
            assert(caught, "child should receive SIGUSR1 from parent")
            exit(0)
        },
        pid => {
            sleep(0.05)
            kill(pid, SIGUSR1)
            wait(pid)
        }
    }
}

pub fn pending-reflects-blocked() {
    let old = Signals(SIGUSR1, SIGUSR2).block()
    Thread.kill(SIGUSR1)
    Thread.kill(SIGUSR2)
    let pnd = Signals.pending
    assert(pnd.contains?(SIGUSR1), "SIGUSR1 should be pending")
    assert(pnd.contains?(SIGUSR2), "SIGUSR2 should be pending")
    pnd.flush()
    old.set()
}

pub fn add-remove() {
    let s = Signals(SIGUSR1)
    s.add(SIGUSR2)
    assert(s.contains?(SIGUSR1), "SIGUSR1 should be in set")
    assert(s.contains?(SIGUSR2), "SIGUSR2 should be in set")
    s.del(SIGUSR1)
    assert(!s.contains?(SIGUSR1), "SIGUSR1 should be removed")
    assert(s.contains?(SIGUSR2), "SIGUSR2 should remain")
}

pub fn clear-fill() {
    let s = Signals.full
    assert(s.contains?(SIGUSR1), "full set should contain SIGUSR1")
    s.clear()
    assert(!s.contains?(SIGUSR1), "cleared set should not contain SIGUSR1")
    s.fill()
    assert(s.contains?(SIGUSR1), "filled set should contain SIGUSR1")
}

pub fn unblock() {
    let old = Signals.block(SIGUSR1)
    assert(Signals.mask.contains?(SIGUSR1), "SIGUSR1 should be blocked")
    Signals(SIGUSR1).unblock()
    assert(!Signals.mask.contains?(SIGUSR1), "SIGUSR1 should be unblocked")
    old.set()
}
