import ty

ns test

fn tag-match-in-loop(nodes) {
    let out = []
    for node in nodes {
        match node {
            [$elems] => {
                for e in elems {
                    match nil { ty.Int($n) => nil, _ => nil }
                }
                out.push(node)
            },
            _ => out.push(node)
        }
    }
    out
}

pub fn test-tag-match-in-loop() {
    let r = tag-match-in-loop([['a', 'b'], ['c'], ['d', 'e', 'f']])
    assert(r == [['a', 'b'], ['c'], ['d', 'e', 'f']])
}

fn overlapping-tags(v: AST) -> Int {
    match v {
        ty.Eq(ty.Int($a), ty.Int($b)) => a + b,
        ty.Eq($a, $b)                 => -1,
        ty.Int($n)                    => n * 10,
        _                             => 0
    }
}

pub fn test-overlapping-tags() {
    assert(overlapping-tags(ty.Eq(ty.Int(3), ty.Int(7)))           == 10)
    assert(overlapping-tags(ty.Eq(ty.String('x'), ty.String('y'))) == -1)
    assert(overlapping-tags(ty.Eq(ty.Int(1), ty.String('z')))      == -1)
    assert(overlapping-tags(ty.Int(5))                              == 50)
    assert(overlapping-tags(ty.Add(ty.Int(1), ty.Int(2)))           == 0)
}

fn tag-try-finally(items: Array[AST]) -> Array[String] {
    let acc = []
    for item in items {
        try {
            match item {
                ty.Int($n) => {
                    if n < 0 { throw "neg" }
                    acc.push("{n}")
                },
                ty.String($s) => acc.push(s),
                _ => acc.push('?')
            }
        } catch e {
            acc.push("caught")
        } finally {
            acc.push('F')
        }
    }
    acc
}

pub fn test-tag-try-finally() {
    let r = tag-try-finally([ty.Int(1), ty.String('hi'), ty.Int(-5), ty.Add(ty.Int(0), ty.Int(0))])
    assert(r == ['1', 'F', 'hi', 'F', 'caught', 'F', '?', 'F'])
}

fn nested-continue(grid: Array[Array[AST]]) -> Array[String] {
    let acc = []
    for row in grid {
        for cell in row {
            match cell {
                ty.Int(0) => {
                    acc.push('skip-row')
                    continue continue
                },
                ty.Int($n) => acc.push("{n}"),
                _          => acc.push('?')
            }
        }
        acc.push('end-row')
    }
    acc
}

pub fn test-nested-continue() {
    let r = nested-continue([
        [ty.Int(1), ty.Int(2)],
        [ty.Int(3), ty.Int(0), ty.Int(99)],
        [ty.Int(4)]
    ])
    assert(r == ['1', '2', 'end-row', '3', 'skip-row', '4', 'end-row'])
}

fn match-as-value(items: Array[AST]) -> Array[String] {
    let out = []
    for item in items {
        let label = match item {
            ty.Int($n) => match n {
                0      => 'zero',
                1..10  => 'small',
                _      => 'big'
            },
            ty.String($s) => "str:{s}",
            _ => 'unknown'
        }
        out.push(label)
    }
    out
}

pub fn test-match-as-value() {
    let r = match-as-value([ty.Int(0), ty.Int(5), ty.Int(100), ty.String('yo'), ty.Add(ty.Int(0), ty.Int(0))])
    assert(r == ['zero', 'small', 'big', 'str:yo', 'unknown'])
}

fn gen-tag-try*(items: Array[AST]) {
    for item in items {
        try {
            let v = match item {
                ty.Int($n) => n * 2,
                _          => -1
            }
            yield v
        } finally {
            ;
        }
    }
}

pub fn test-gen-tag-try() {
    let r = [x for x in gen-tag-try([ty.Int(3), ty.Add(ty.Int(0), ty.Int(0)), ty.Int(7)])]
    assert(r == [6, -1, 14])
}

fn deep-nest(data: Array[Array[AST]]) -> Array[Int] {
    let acc = []
    for batch in data {
        try {
            for item in batch {
                let v = -2
                match item {
                    ty.Cond($inner, _, _) => {
                        try {
                            match inner {
                                ty.Int($n) => {
                                    if n > 100 { throw 'overflow' }
                                    v = n
                                },
                                _ => { v = 0 }
                            }
                        } catch e {
                            v = -1
                        }
                    },
                    ty.Int($n) => { v = n },
                    _ => nil
                }
                acc.push(v)
            }
        } catch e {
            acc.push(-99)
        }
    }
    acc
}

pub fn test-deep-nest() {
    let r = deep-nest([
        [ty.Cond(ty.Int(10), ty.Int(0), ty.Int(0)), ty.Cond(ty.Int(200), ty.Int(0), ty.Int(0)), ty.Cond(ty.String('x'), ty.Int(0), ty.Int(0)), ty.Int(42)],
        [ty.Cond(ty.Int(5), ty.Int(0), ty.Int(0))]
    ])
    assert(r == [10, -1, 0, 42, 5])
}

fn break-break-tag(matrix: Array[Array[AST]]) -> Int {
    let found = -1
    for row in matrix {
        for cell in row {
            match cell {
                ty.Int($n) and n == 42 => {
                    found = n
                    break break
                },
                ty.Int($n) => nil,
                _ => nil
            }
        }
    }
    found
}

pub fn test-break-break-tag() {
    let r = break-break-tag([[ty.Int(1), ty.Int(2)], [ty.Int(3), ty.Int(42), ty.Int(99)]])
    assert(r == 42)
}

fn choice-tags(v: AST) -> String {
    match v {
        ty.Int(0), ty.Int(1) => 'binary',
        ty.Int($n)           => "int:{n}",
        ty.String($s)        => "str:{s}",
        _                    => 'other'
    }
}

pub fn test-choice-tags() {
    assert(choice-tags(ty.Int(0))      == 'binary')
    assert(choice-tags(ty.Int(1))      == 'binary')
    assert(choice-tags(ty.Int(99))     == 'int:99')
    assert(choice-tags(ty.String('x')) == 'str:x')
    assert(choice-tags(ty.Add(ty.Int(0), ty.Int(0))) == 'other')
}

fn while-tag-match(items: Array[AST]) -> Array[Int] {
    let acc = []
    let i = 0
    while i < items.len() {
        let v = match items[i] {
            ty.Int($n) => n,
            ty.String($s) => s.len(),
            _ => 0
        }
        acc.push(v)
        i += 1
    }
    acc
}

pub fn test-while-tag-match() {
    assert(while-tag-match([ty.Int(3), ty.String('ab'), ty.Add(ty.Int(0), ty.Int(0)), ty.Int(7)]) == [3, 2, 0, 7])
}

fn tag-match-try-result(items: Array[AST]) -> Array[Int] {
    let acc = []
    for item in items {
        let v = try {
            match item {
                ty.Int($n) => {
                    if n < 0 { throw 'neg' }
                    n
                },
                _ => 0
            }
        } catch _ {
            -1
        }
        acc.push(v)
    }
    acc
}

pub fn test-tag-match-try-result() {
    assert(tag-match-try-result([ty.Int(5), ty.Int(-3), ty.Add(ty.Int(0), ty.Int(0))]) == [5, -1, 0])
}

fn closure-capture-tag(items: Array[AST]) -> Array[Int] {
    let fns = []
    for item in items {
        let val = match item {
            ty.Int($n) => n,
            _ => 0
        }
        fns.push(fn () -> Int { val })
    }
    fns.map(fn (f) { f() })
}

pub fn test-closure-capture-tag() {
    assert(closure-capture-tag([ty.Int(10), ty.Add(ty.Int(0), ty.Int(0)), ty.Int(30)]) == [10, 0, 30])
}

fn sequential-tag-matches(a: AST, b: AST, c: AST) -> Int {
    let x = match a { ty.Int($n) => n, _ => 0 }
    let y = match b { ty.Int($n) => n, _ => 0 }
    let z = match c { ty.Int($n) => n, _ => 0 }
    x + y + z
}

pub fn test-sequential-tag-matches() {
    assert(sequential-tag-matches(ty.Int(1), ty.Int(2), ty.Int(3)) == 6)
    assert(sequential-tag-matches(ty.Int(1), ty.Add(ty.Int(0), ty.Int(0)), ty.Int(3)) == 4)
    assert(sequential-tag-matches(ty.Add(ty.Int(0), ty.Int(0)), ty.Add(ty.Int(0), ty.Int(0)), ty.Add(ty.Int(0), ty.Int(0))) == 0)
}

pub fn test-for-value-tag() {
    let r = for item in [ty.Int(1), ty.Int(2), ty.Int(42), ty.Int(99)] {
        match item {
            ty.Int($n) and n == 42 => break n,
            _ => nil
        }
    }
    assert(r == 42)
}

fn try-cc-tag(grid: Array[Array[AST]]) -> Array[String] {
    let acc = []
    for row in grid {
        for cell in row {
            try {
                match cell {
                    ty.Int(0) => {
                        acc.push('cc')
                        continue continue
                    },
                    ty.Int($n) => acc.push("{n}"),
                    _ => acc.push('?')
                }
            } finally {
                acc.push('F')
            }
        }
        acc.push('end')
    }
    acc
}

pub fn test-try-cc-tag() {
    let r = try-cc-tag([
        [ty.Int(1), ty.Int(2)],
        [ty.Int(3), ty.Int(0), ty.Int(99)],
        [ty.Int(4)]
    ])
    assert(r == ['1', 'F', '2', 'F', 'end', '3', 'F', 'cc', 'F', '4', 'F', 'end'])
}

fn double-tag-match(outer: AST, inner: AST) -> Int {
    let a = match outer {
        ty.Int($n) => n,
        _ => 0
    }
    let b = match inner {
        ty.Int($n) => n,
        _ => 0
    }
    a * 100 + b
}

pub fn test-double-tag-match() {
    assert(double-tag-match(ty.Int(3), ty.Int(7))                        == 307)
    assert(double-tag-match(ty.Int(3), ty.String('x'))                   == 300)
    assert(double-tag-match(ty.String('x'), ty.Int(7))                   == 7)
    assert(double-tag-match(ty.String('x'), ty.Add(ty.Int(0), ty.Int(0))) == 0)
}

fn tag-match-stmt(items: Array[AST]) -> Array[String] {
    let acc = []
    for item in items {
        match item {
            ty.Int($n) and n > 10 => acc.push('big'),
            ty.Int($n) => acc.push('small'),
            ty.String($s) => acc.push(s),
            _ => acc.push('other')
        }
    }
    acc
}

pub fn test-tag-match-stmt() {
    let r = tag-match-stmt([ty.Int(5), ty.Int(20), ty.String('hi'), ty.Add(ty.Int(0), ty.Int(0))])
    assert(r == ['small', 'big', 'hi', 'other'])
}

fn stress-default(n: Int) -> Int {
    let sum = 0
    for i in ..n {
        let v = match ty.String('x') {
            ty.Int($k) => k,
            _ => i
        }
        sum += v
    }
    sum
}

pub fn test-stress-default() {
    assert(stress-default(100) == 4950)
}
