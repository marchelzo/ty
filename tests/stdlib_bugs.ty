import os
import stdio
import io
import errno
import time

ns test

pub fn test-os-read-all() {
    let (r, w) = os.pipe()!
    let data = Blob()
    for i in ..100 {
        data.push(i % 256)
    }
    os.write(w, data)
    os.close(w)
    let result = os.read(r, 100, all: true)
    os.close(r)
    if result == nil {
        throw "os.read returned nil"
    }
    assert(#result == 100)
    for i in ..100 {
        assert(result[i] == i % 256)
    }
}

pub fn test-os-read-all-into-blob() {
    let (r, w) = os.pipe()!
    let data = Blob()
    for i in ..200 {
        data.push(i % 256)
    }
    os.write(w, data)
    os.close(w)
    let buf = Blob()
    let n = os.read(r, buf, 200, all: true)
    os.close(r)
    assert(n == 200)
    assert(#buf == 200)
    for i in ..200 {
        assert(buf[i] == i % 256)
    }
}

pub fn test-stdio-write-read-signed() {
    let (fd, path) = os.mktemp()!
    os.close(fd)
    let f = stdio.fdopen(os.open(path, os.O_RDWR), 'w+')
    assert(f != nil)
    stdio.writeSigned(f, 42)
    stdio.fflush(f)
    stdio.fseek(f, 0, 0)
    let val = stdio.readSigned(f)
    assert(val == 42)
    stdio.fseek(f, 0, 0)
    stdio.writeSigned(f, 1, -5)
    stdio.fflush(f)
    stdio.fseek(f, 0, 0)
    let val2 = stdio.readSigned(f, 1)
    assert(val2 == -5)
    stdio.fclose(f)
    os.unlink(path)
}

pub fn test-stdio-write-read-unsigned() {
    let (fd, path) = os.mktemp()!
    os.close(fd)
    let f = stdio.fdopen(os.open(path, os.O_RDWR), 'w+')
    assert(f != nil)
    stdio.writeUnsigned(f, 255)
    stdio.fflush(f)
    stdio.fseek(f, 0, 0)
    let val = stdio.readUnsigned(f)
    assert(val == 255)
    stdio.fclose(f)
    os.unlink(path)
}

pub fn test-stdio-fwrite-blob-len() {
    let (fd, path) = os.mktemp()!
    os.close(fd)
    let f = stdio.fdopen(os.open(path, os.O_RDWR), 'w+')
    assert(f != nil)
    let data = Blob()
    for i in ..10 {
        data.push(65 + i)
    }
    let written = stdio.fwrite(f, data, 5)
    assert(written == 5)
    stdio.fflush(f)
    stdio.fseek(f, 0, 0)
    let result = stdio.fread(f, 100) ?? throw "fread returned nil"
    assert(#result == 5)
    for i in ..5 {
        assert(result[i] == 65 + i)
    }
    stdio.fclose(f)
    os.unlink(path)
}

pub fn test-stdio-fwrite-string-and-ptr() {
    let (fd, path) = os.mktemp()!
    os.close(fd)
    let f = stdio.fdopen(os.open(path, os.O_RDWR), 'w+')
    assert(f != nil)
    let written = stdio.fwrite(f, "Hello, World!", 5)
    assert(written == 5)
    stdio.fflush(f)
    stdio.fseek(f, 0, 0)
    let result = stdio.fread(f, 100)
    assert(result != nil)
    assert(#result == 5)
    assert(result.str() == 'Hello')
    stdio.fclose(f)
    os.unlink(path)
}

pub fn test-pipe-roundtrip() {
    let (r, w) = os.pipe()!
    let msg = "Hello from pipe!"
    os.write(w, msg)
    os.close(w)
    let got = os.read(r, 1024)
    os.close(r)
    assert(got != nil)
    assert(got.str() == msg)
}

pub fn test-slurp-preserves-user-fd() {
    let (fd, path) = os.mktemp()!
    os.write(fd, "hello world")
    let fd2 = os.open(path, os.O_RDONLY)
    let content = slurp(fd2)
    assert(content == "hello world")
    let st = os.fstat(fd2)
    assert(st != nil)
    os.close(fd2)
    os.close(fd)
    os.unlink(path)
}

pub fn test-getaddrinfo-nil-port() {
    match os.getaddrinfo("localhost", nil, 0, 0, 0) {
        Ok(results) => {
            assert(results.len() > 0)
        },
        Err(code) => {
        }
    }
}

pub fn test-sendto-no-addr() {
    let sock = os.socket(os.AF_INET, os.SOCK_DGRAM, 0)
    os.bind(sock, {family: os.AF_INET, address: 0x7f000001, port: 0})
    let local = os.getsockname(sock)
    os.connect(sock, {family: os.AF_INET, address: 0x7f000001, port: local[2] * 256 + local[3]})
    let n = os.sendto(sock, "hi", 0)
    assert(n == 2)
    os.close(sock)
}

pub fn test-accept-large-addr() {
    let srv = os.socket(os.AF_UNIX, os.SOCK_STREAM, 0)
    let (_, path) = os.mktemp()!
    os.unlink(path)
    os.bind(srv, {family: os.AF_UNIX, path: path})
    os.listen(srv, 1)
    let cli = os.socket(os.AF_UNIX, os.SOCK_STREAM, 0)
    os.connect(cli, {family: os.AF_UNIX, path: path})
    let (fd, addr) = os.accept(srv)!
    assert(fd >= 0)
    os.close(fd)
    os.close(cli)
    os.close(srv)
    os.unlink(path)
}

pub fn test-strftime-isdst() {
    let result = time.strftime('%Z', {
        sec: 0, min: 0, hour: 12,
        mday: 1, mon: 6, year: 124,
        wday: 1, yday: 182, isdst: 0,
    })
    assert(result != nil)
    let result2 = time.strftime('%Z', {
        sec: 0, min: 0, hour: 12,
        mday: 1, mon: 6, year: 124,
        wday: 1, yday: 182, isdst: 1,
    })
    assert(result2 != nil)
}
