ns test

pub fn len() {
    let s = 'hello world'
    assert(#s == 11)
    assert(s.len() == 11)
    assert(s.size() == 11)
    assert(''.len() == 0)
    assert(''.size() == 0)
    assert(#'' == 0)
    assert('café'.len() == 4)
    assert('café'.size() == 5)
    assert('café'.charCount() == 4)
    assert('abc'.charCount() == 3)
    assert(''.charCount() == 0)
}

pub fn indexing() {
    let s = 'hello world'
    assert(s[0] == 'h')
    assert(s[5] == ' ')
    assert(s[10] == 'd')
    assert(s[-1] == 'd')
    assert(s[-11] == 'h')
    assert('café'[3] == 'é')
    assert('café'[-1] == 'é')
    assert('café'[0] == 'c')
}

pub fn char-method() {
    assert('hello'.char(0) == 'h')
    assert('hello'.char(4) == 'o')
    assert('hello'.char(-1) == 'o')
    assert('hello'.char(-5) == 'h')
    assert('hello'.char(5) == nil)
}

pub fn byte-method() {
    assert('abc'.byte(0) == 97)
    assert('abc'.byte(1) == 98)
    assert('abc'.byte(2) == 99)
    assert('abc'.byte(-1) == 99)
    assert('abc'.byte(-3) == 97)
    assert('abc'.byte(3) == nil)
    assert('abc'.byte(-4) == nil)
}

pub fn chars() {
    let s = 'hello world'
    assert(s.chars() == ['h', 'e', 'l', 'l', 'o', ' ', 'w', 'o', 'r', 'l', 'd'])
    assert(''.chars() == [])
    assert('a'.chars() == ['a'])
    assert('café'.chars() == ['c', 'a', 'f', 'é'])
}

pub fn bytes() {
    assert('abc'.bytes() == [97, 98, 99])
    assert(''.bytes() == [])
}

pub fn upper-lower() {
    let s = 'hello world'
    assert(s.upper() == 'HELLO WORLD')
    assert(s.upper().lower() == s.lower())
    assert(s.upper().lower() == s)
    assert('ABC'.lower() == 'abc')
    assert('abc'.upper() == 'ABC')
    assert(''.upper() == '')
    assert(''.lower() == '')
    assert('123'.upper() == '123')
    assert('MiXeD'.lower() == 'mixed')
    assert('MiXeD'.upper() == 'MIXED')
}

pub fn words() {
    let s = 'hello world'
    assert(s.words() == ['hello', 'world'])
    assert('  hello  world  '.words() == ['hello', 'world'])
    assert('hello'.words() == ['hello'])
    assert(''.words() == [])
    assert('   '.words() == [])
    assert('  hello  '.words() == ['hello'])
    assert('a    b    c'.words() == ['a', 'b', 'c'])
    assert("hello\nworld".words() == ['hello', 'world'])
    assert("hello\r\nworld".words() == ['hello', 'world'])
}

pub fn lines() {
    assert(''.lines() == [''])
    assert("hello\nworld".lines() == ['hello', 'world'])
    assert("hello\r\nworld".lines() == ['hello', 'world'])
    assert("hello\nworld\n".lines() == ['hello', 'world'])
    assert("hello\r\nworld\r\n".lines() == ['hello', 'world'])
    assert("hello\n\nworld".lines() == ['hello', '', 'world'])
    assert("\n\n".lines() == ['', ''])
    assert("\n".lines() == [''])
    assert('hello'.lines() == ['hello'])
    assert("a\rb".lines() == ["a\rb"])
}

pub fn split-string() {
    let s = 'hello world'
    assert(s.split(' ') == ['hello', 'world'])
    assert('a-b-c'.split('-') == ['a', 'b', 'c'])
    assert('a,,b,,c'.split(',') == ['a', '', 'b', '', 'c'])
    assert('-a-b-'.split('-') == ['', 'a', 'b', ''])
    assert('--'.split('-') == ['', '', ''])
    assert('abc'.split('x') == ['abc'])
    assert('a::b::c'.split('::') == ['a', 'b', 'c'])
    assert('a,,b,,c'.split(',', 2) == ['a', '', 'b,,c'])
    assert(',a,'.split(',') == ['', 'a', ''])
    assert(',,'.split(',') == ['', '', ''])
    assert('a::b'.split('::') == ['a', 'b'])
    assert('::a::b::'.split('::') == ['', 'a', 'b', ''])
    assert('a,b,c,'.split(',') == ['a', 'b', 'c', ''])
    assert(','.split(',') == ['', ''])
    assert('a'.split(',') == ['a'])
}

pub fn split-regex() {
    assert('hello world'.split(/\s+/) == ['hello', 'world'])
    assert('a1b2c'.split(/\d/) == ['a', 'b', 'c'])
    assert('hello world'.split(/(\s+)/) == ['hello', ' ', 'world'])
    assert('abc'.split(/(\w)(\w)/) == ['', 'a', 'b', 'c'])
    assert('a b c'.split(/\s/, 1) == ['a', 'b c'])
    assert('a1b2c3'.split(/\d/) == ['a', 'b', 'c', ''])
    assert('1a2b3c'.split(/\d/) == ['', 'a', 'b', 'c'])
}

pub fn split-int() {
    assert('hello'.split(0) == ('', 'hello'))
    assert('hello'.split(1) == ('h', 'ello'))
    assert('hello'.split(5) == ('hello', ''))
    assert('hello'.split(-1) == ('hell', 'o'))
    assert(''.split(0) == ('', ''))
    assert('abc'.split(-100) == ('', 'abc'))
    assert('abc'.split(100) == ('abc', ''))
}

pub fn split-limit() {
    assert('a-b-c'.split('-', 0) == ['a-b-c'])
    assert('a-b-c'.split('-', 1) == ['a', 'b-c'])
    assert('a-b-c'.split('-', 100) == ['a', 'b', 'c'])
}

pub fn search() {
    assert('hello world'.search('world') == 6)
    assert('hello world'.search('hello') == 0)
    assert('hello world'.search('xyz') == nil)
    assert('hello'.search('ello') == 1)
    assert('abcabc'.search('b', 0) == 1)
    assert('abcabc'.search('b', 2) == 4)
    assert('abc'.search('b', 2) == nil)
    assert('abc'.search('b', -2) == 1)
    assert('abc'.search(/a/) == 0)
    assert('abc'.search(/c/) == 2)
    assert('abc'.search(/x/) == nil)
    assert('abc'.search(/b/, 0) == 1)
    assert('abc'.search('a') == 0)
    assert('abc'.search('c') == 2)
    assert('abc'.search('abc') == 0)
    assert('abc'.search('abcd') == nil)
    assert('abc'.search(/^/) == 0)
    assert('abcabc'.search('a', 1) == 3)
    assert('abcabc'.search(/a/, 1) == 3)
    assert('abcabc'.search('a', -3) == 3)
}

pub fn searchr() {
    assert('abcabc'.searchr('a') == 3)
    assert('abc'.searchr('a') == 0)
    assert('abc'.searchr('x') == nil)
    assert('abcabc'.searchr(/a/) == 3)
}

pub fn search-all() {
    assert('abcabc'.searchAll('b') == [1, 4])
    assert('abc'.searchAll('x') == [])
    assert('aaa'.searchAll('a') == [0, 1, 2])
    assert('hello world'.searchAll(/\w+/) == [0, 6])
    assert('abc'.searchAll('a') == [0])
    assert(''.searchAll('a') == [])
    assert('abc'.searchAll('abc') == [0])
    assert('aaa'.searchAll('a') == [0, 1, 2])
    assert('aaaa'.searchAll('aa') == [0, 2])
}

pub fn contains() {
    assert('hello world'.contains?('hello') == true)
    assert('hello world'.contains?('xyz') == false)
    assert('hello world'.contains?('') == true)
    assert(''.contains?('') == false)
    assert('hello'.contains?(/^h/) == true)
    assert('hello'.contains?(/^x/) == false)
}

pub fn count() {
    assert('aabaa'.count('a') == 4)
    assert('aabaa'.count('b') == 1)
    assert('aabaa'.count('x') == 0)
    assert('aaaa'.count('aa') == 2)
    assert('hello world'.count(/o/) == 2)
    assert('hello world'.count(/\w+/) == 2)
    assert('aaaa'.count(/aa/) == 2)
    assert(''.count('a') == 0)
    assert('a'.count('a') == 1)
    assert('aaa'.count('a') == 3)
    assert('abc'.count('abc') == 1)
    assert('abcabc'.count('abc') == 2)
    assert(''.count(/\w/) == 0)
    assert('abc'.count(/./) == 3)
    assert('abc'.count('') == 0)
    assert('abc'.count(/(?=\w)/) == 3)
    assert('abc'.count(/\b/) == 2)
    assert(''.count(/(?=.)/) == 0)
}

pub fn match-basic() {
    assert('abc'.match(/\w+/) == 'abc')
    assert('abc'.match(/^abc$/) == 'abc')
    assert('abc'.match(/xyz/) == nil)
    assert('abc'.match(/(.)(.)(.)/) == ['abc', 'a', 'b', 'c'])
    assert('abc'.match(/(.)(.)/) == ['ab', 'a', 'b'])
    assert('a(b)c'.match(/\((\w)\)/) == ['(b)', 'b'])
}

pub fn match-v-flag() {
    let m = 'abc'.match(/(\w)(\w)/v)
    assert(m.groups == ['ab', 'a', 'b'])
    assert('abc'.match(/xyz/v) == nil)
    let m2 = 'abc'.match(/\w+/v)
    assert(m2.groups == ['abc'])
}

pub fn match-pred() {
    assert('abc'.match?(/^abc$/) == true)
    assert('abc'.match?(/xyz/) == false)
    assert(''.match?(/^$/) == true)
    assert('hello world'.match?(/\w+/) == true)
    assert('abc'.match?(/^$/) == false)
    assert(''.match?(/^$/) == true)
    assert('abc'.match?(/./) == true)
    assert(''.match?(/./) == false)
    assert('hello world'.match?(/world/) == true)
    assert('hello world'.match?(/^hello$/) == false)
    assert('hello world'.match?(/^hello/) == true)
}

pub fn match-anchors() {
    assert('abc'.match(/^abc$/) == 'abc')
    assert('abc'.match(/^xyz$/) == nil)
    assert('abc'.match(/^a/) == 'a')
    assert('abc'.match(/c$/) == 'c')
    assert('abc'.match(/^(.)(.)$/) == nil)
    assert('ab'.match(/^(.)(.)$/) == ['ab', 'a', 'b'])
}

pub fn match-complex-regex() {
    assert('2024-01-15'.match(/(\d{4})-(\d{2})-(\d{2})/) == ['2024-01-15', '2024', '01', '15'])
    assert('cat'.match(/(cat|dog)/) == ['cat', 'cat'])
    assert('dog'.match(/(cat|dog)/) == ['dog', 'dog'])
    assert('bird'.match(/(cat|dog)/) == nil)
    assert('aabbb'.match(/(a+)(b+)/) == ['aabbb', 'aa', 'bbb'])
    assert('Hello'.match?(/hello/i) == true)
    assert('Hello'.match(/hello/i) == 'Hello')
}

pub fn regex-match-obj() {
    let rm = 'hello world'.match(/(\w+)\s+(\w+)/v)
    assert(rm.groups[0] == 'hello world')
    assert(rm.groups[1] == 'hello')
    assert(rm.groups[2] == 'world')
}

pub fn match-optional-groups() {
    let ov = 'abc'.match(/^(\w)(\w)?(\w)?/v)
    assert(ov.groups[0] == 'abc')
    assert(ov.groups[1] == 'a')
    assert(ov.groups[2] == 'b')
    assert(ov.groups[3] == 'c')
    let ov2 = 'a'.match(/^(\w)(\w)?(\w)?/v)
    assert(ov2.groups[0] == 'a')
    assert(ov2.groups[1] == 'a')
}

pub fn match-alternation-groups() {
    let alt = 'abc123'.match(/([a-z]+)(\d+)/)
    assert(alt == ['abc123', 'abc', '123'])
}

pub fn scan() {
    assert('foo bar'.scan(/\w+/) == ['foo', 'bar'])
    assert('abc'.scan(/\w/) == ['a', 'b', 'c'])
    assert(''.scan(/\w+/) == [])
    assert('hello world'.scan(/\b\w+\b/) == ['hello', 'world'])
    assert('foo bar'.scan(/(\w)(\w+)/) == [['foo', 'f', 'oo'], ['bar', 'b', 'ar']])
    assert('abc'.scan(/(\w)/) == [['a', 'a'], ['b', 'b'], ['c', 'c']])
    assert('abc'.scan(/(?=\w)/) == ['', '', ''])
    assert('abc'.scan(/(?=.)/) == ['', '', ''])
    assert(''.scan(/(?=.)/) == [])
    assert('abc'.scan(/\b/) == ['', ''])
    assert('one two three'.scan(/\b\w+\b/) == ['one', 'two', 'three'])
    assert('no-match-here'.scan(/\b\w+\b/) == ['no', 'match', 'here'])
    assert('a1b2c3'.scan(/\d/) == ['1', '2', '3'])
    assert('a1b2c3'.scan(/[a-z]/) == ['a', 'b', 'c'])
    assert('  x  y  '.scan(/\w/) == ['x', 'y'])
}

pub fn scan-v-flag() {
    let ms = 'foo bar'.scan(/(\w)(\w+)/v)
    assert(#ms == 2)
    assert(ms[0].groups == ['foo', 'f', 'oo'])
    assert(ms[1].groups == ['bar', 'b', 'ar'])
    let sv = 'abc'.scan(/\w/v)
    assert(#sv == 3)
    assert(sv[0].groups == ['a'])
    assert(sv[1].groups == ['b'])
    assert(sv[2].groups == ['c'])
}

pub fn sub-string() {
    assert('hello world'.sub('world', 'earth') == 'hello earth')
    assert('aaa'.sub('a', 'b') == 'bbb')
    assert('abcabc'.sub('a', 'A') == 'AbcAbc')
    assert('abc'.sub('x', 'y') == 'abc')
    assert('banana'.sub('a', 'o') == 'bonono')
    assert('hello'.sub('l', 'r') == 'herro')
    assert(''.sub('', '-') == '')
    assert('abc'.sub('', '-') == 'abc')
    assert('aaa'.sub('aa', 'x') == 'xa')
    assert('abc'.sub('abc', '') == '')
    assert('abc'.sub('abc', 'xyz') == 'xyz')
    assert('axa'.sub('a', 'b') == 'bxb')
}

pub fn sub-regex() {
    assert('hello world'.sub(/\w+/, 'X') == 'X X')
    assert('abc'.sub(/[aeiou]/, '-') == '-bc')
    assert('abc'.sub(/(?=b)/, '-') == 'a-bc')
    assert('abc'.sub(/^/, 'X') == 'Xabc')
    assert('abc'.sub(/$/, 'X') == 'abcX')
    assert('abc'.sub(/(?=\w)/, |_| -> '-') == '-a-b-c')
    assert('hello world'.sub(/[aeiou]/, '*') == 'h*ll* w*rld')
    assert('HELLO'.sub(/[A-Z]/, \_.lower()) == 'hello')
    assert('--abc--'.sub(/\w+/, 'X') == '--X--')
    assert('  abc  def  '.sub(/\w+/, 'X') == '  X  X  ')
    assert('banana'.sub(/a/, 'o') == 'bonono')
    assert('aaa'.sub(/a/, 'b') == 'bbb')
    assert('a1b2c3'.sub(/\d/, '#') == 'a#b#c#')
    assert('abc'.sub(/\w/, '') == '')
    assert('abc'.sub(/x/, 'y') == 'abc')
    assert('axa'.sub(/a/, 'b') == 'bxb')
    assert('abc'.sub(/\w/, 'xx') == 'xxxxxx')
    assert('abc'.sub(/\w+/, '') == '')
    assert('a b c'.sub(/\s/, '') == 'abc')
}

pub fn sub-callback() {
    assert('hello world'.sub(/\w+/, \_.upper()) == 'HELLO WORLD')
    assert('abc'.sub(/\w/, \_.upper()) == 'ABC')
    assert('abc'.sub(/(\w)/, |[_, c]| -> c.upper()) == 'ABC')
    assert('hello world'.sub(/\w+/, |m| -> m.upper()) == 'HELLO WORLD')
    fn capitalize(m: String) { m[0].upper() + m[1;] }
    assert('hello world'.sub(/\w+/, capitalize) == 'Hello World')
    assert('abc'.sub(/\w+/, |m| -> "{#m}") == '3')
    assert('abc'.sub(/(\w+)/, |m| -> "{#m}") == '2')
    assert('abc'.sub(/\w+/, |_| -> 42) == '42')
    fn never(m) { throw 'never'; '' }
    assert('abc'.sub(/xyz/, never) == 'abc')
}

pub fn comb() {
    assert('abc'.comb(/[aeiou]/) == 'bc')
    assert('hello world'.comb(/\w+/) == ' ')
    assert('abc'.comb(/xyz/) == 'abc')
    assert('aeiou'.comb(/[aeiou]/) == '')
    assert('abc'.comb('b') == 'ac')
    assert('abcabc'.comb('a') == 'bcbc')
    assert('abc'.comb('x') == 'abc')
    assert('aaa'.comb('a') == '')
    assert('abc'.comb(/(?=b)/) == 'abc')
    assert('a1b2c3'.comb(/\d/) == 'abc')
    assert('a1b2c3'.comb(/[a-z]/) == '123')
    assert('  hello  '.comb(/ /) == 'hello')
    assert('hello'.comb('hello') == '')
    assert('Hello, World!'.comb(/[^a-zA-Z]/) == 'HelloWorld')
    assert('Hello, World!'.comb(/\W/) == 'HelloWorld')
}

pub fn comb-pred() {
    assert('abc'.comb?('x') == nil)
    assert('abc'.comb?(/xyz/) == nil)
    assert('abc'.comb?('b') == 'ac')
    assert('hello world'.comb?(/\w+/) == ' ')
    assert('abc'.comb?('a') == 'bc')
    assert('abc'.comb?(/^a/) == 'bc')
    assert('abc'.comb?('d') == nil)
    assert(''.comb?('a') == nil)
}

pub fn slice() {
    assert('abc'.slice(0) == 'abc')
    assert('abc'.slice(1) == 'bc')
    assert('abc'.slice(2) == 'c')
    assert('abc'.slice(3) == '')
    assert('abc'.slice(0, 2) == 'ab')
    assert('abc'.slice(1, 2) == 'bc')
    assert('abc'.slice(1, 1) == 'b')
    assert('abc'.slice(-2) == 'bc')
    assert('abc'.slice(-1) == 'c')
    assert('hello'.slice(-3, 2) == 'll')
    assert('abc'.slice(0, 100) == 'abc')
    assert('abc'.slice(100) == '')
    assert(''.slice(0) == '')
    assert(''.slice(0, 0) == '')
    assert('abc'.slice(-100) == 'abc')
    assert('abc'.slice(0, 0) == '')
}

pub fn bslice() {
    assert('abc'.bslice(0) == 'abc')
    assert('abc'.bslice(1) == 'bc')
    assert('abc'.bslice(1, 2) == 'bc')
    assert('abc'.bslice(0, 0) == '')
    assert('abc'.bslice(-2) == 'bc')
    assert('abc'.bslice(-1) == 'c')
    assert(''.bslice(0) == '')
    assert('abc'.bslice(0, 3) == 'abc')
    assert('abc'.bslice(3) == '')
}

pub fn slice-syntax() {
    assert('abcde'[0;3] == 'abc')
    assert('abcde'[1;3] == 'bcd')
    assert('abcde'[1;] == 'bcde')
    assert('abcde'[;3] == 'abc')
    assert('abcde'[-2;] == 'de')
    assert('abcde'[;-1] == 'abcd')
    assert('abcde'[2;2] == 'cd')
    try { 'abcde'[0;5;2]; assert(false, 'expected exception') }
    catch _ { }
}

pub fn string-offset() {
    assert('abc' + 0 == 'abc')
    assert('abc' + 1 == 'bc')
    assert('abc' + 2 == 'c')
    assert('abc' + 3 == '')
    assert('abc' + 1 - 1 == 'abc')
    assert('abc' + 2 - 2 == 'abc')
    assert('abc' + 3 - 3 == 'abc')
    assert('abc' + true == 'bc')
    assert('abc' + false == 'abc')
    assert('abc' - true == 'abc')
    assert('bc' - false == 'bc')
    assert('abc' - 1 == 'abc')
    assert('abc' - 100 == 'abc')
    assert('abc' + 100 == '')
    assert('' + 1 == '')
}

pub fn concat() {
    assert('abc' + 'def' == 'abcdef')
    assert('' + 'abc' == 'abc')
    assert('abc' + '' == 'abc')
    assert('' + '' == '')
}

pub fn repeat() {
    assert('abc' * 3 == 'abcabcabc')
    assert('abc' * 1 == 'abc')
    assert('abc' * 0 == '')
    assert('' * 100 == '')
    assert('abc'.repeat(3) == 'abcabcabc')
    assert('abc'.repeat(1) == 'abc')
    assert('abc'.repeat(0) == '')
    assert(''.repeat(5) == '')
    assert('a'.repeat(5) == 'aaaaa')
    assert('ab'.repeat(0) == '')
}

pub fn comparison() {
    assert('abc' == 'abc')
    assert('abc' != 'abd')
    assert('abc' < 'abd')
    assert('abd' > 'abc')
    assert('abc' <= 'abc')
    assert('abc' <= 'abd')
    assert('abc' >= 'abc')
    assert('abd' >= 'abc')
    assert(('abc' <=> 'abc') == 0)
    assert(('abc' <=> 'abd') == -1)
    assert(('abd' <=> 'abc') == 1)
    assert('' < 'a')
    assert('' <= '')
    assert('' == '')
    assert('ab' < 'abc')
    assert('abc' > 'ab')
    assert('a' < 'b')
    assert('z' > 'a')
}

pub fn pad() {
    assert('abc'.lpad(10) == '       abc')
    assert('abc'.rpad(10) == 'abc       ')
    assert('abc'.pad(10) == 'abc       ')
    assert('abc'.lpad(10, '0') == '0000000abc')
    assert('abc'.rpad(10, '0') == 'abc0000000')
    assert('abcdef'.lpad(3) == 'abcdef')
    assert('abcdef'.rpad(3) == 'abcdef')
    assert('x'.lpad(7, 'ab') == 'abababx')
    assert('abc'.lpad(3) == 'abc')
    assert('abc'.rpad(3) == 'abc')
    assert('abc'.lpad(4) == ' abc')
    assert('abc'.rpad(4) == 'abc ')
}

pub fn clone() {
    assert('abc'.clone() == 'abc')
    assert(''.clone() == '')
}

pub fn bsearch() {
    assert('abc'.bsearch('b') == 1)
    assert('abc'.bsearch('c') == 2)
    assert('abc'.bsearch('x') == nil)
    assert('abcabc'.bsearch('b', 2) == 4)
    assert('abc'.bsearch(/b/) == 1)
    assert('abc'.bsearch('a') == 0)
    assert('abc'.bsearch('a', 1) == nil)
    assert('abc'.bsearch(/\w/, 1) == 1)
    assert('abc'.bsearch('c', 2) == 2)
}

pub fn empty-string-ops() {
    assert(''.upper() == '')
    assert(''.lower() == '')
    assert(''.chars() == [])
    assert(''.bytes() == [])
    assert(''.count('a') == 0)
    assert(''.contains?('') == false)
    assert(''.search('a') == nil)
    assert(''.scan(/\w/) == [])
    assert(''.match(/\w/) == nil)
    assert(''.match?(/\w/) == false)
    assert(''.match?(/^$/) == true)
}

pub fn single-char-ops() {
    assert('a'.upper() == 'A')
    assert('A'.lower() == 'a')
    assert('a'.chars() == ['a'])
    assert('a'.bytes() == [97])
    assert('a'.len() == 1)
    assert('a'.size() == 1)
    assert('a'[0] == 'a')
    assert('a'[-1] == 'a')
}

pub fn interpolation() {
    let x = 42
    assert("{x}" == '42')
    assert("hello {x} world" == 'hello 42 world')
}

pub fn unicode() {
    assert('HELLO'.lower() == 'hello')
    assert('hello'.upper() == 'HELLO')
    assert('café'.search('é') == 3)
    assert('café'.contains?('fé') == true)
    assert('café'.match?(/café/) == true)
    assert('café'.scan(/\w+/) == ['caf'])
    assert('café'.scan(/[a-zé]+/) == ['café'])
    assert('café'.scan(/\w+/u) == ['café'])
    assert('café résumé'.scan(/\w+/u) == ['café', 'résumé'])
    assert('über'.match?(/^\w+$/u) == true)
    assert('naïve'.match(/\w+/u) == 'naïve')
    assert('naïve'.count(/\w+/u) == 1)
    assert('naïve test'.sub(/\w+/u, \_.upper()) == 'NAÏVE TEST')
}

pub fn unicode-offset() {
    let u = 'café'
    assert(u + 1 == 'afé')
    assert(u + 1 - 1 == 'café')
    assert(u + 4 == '')
    assert(u + 4 - 4 == 'café')
}

pub fn regex-special-chars() {
    assert('hello.world'.match(/\./) == '.')
    assert('a+b'.match(/\+/) == '+')
    assert('a*b'.sub(/\*/, 'x') == 'axb')
    assert('(abc)'.match(/\((\w+)\)/) == ['(abc)', 'abc'])
}

pub fn chained-ops() {
    assert('  Hello World  '.words().map(\_.lower()) == ['hello', 'world'])
    assert('a,b,c'.split(',').map(\_.upper()) == ['A', 'B', 'C'])
    assert('abc'.chars().map(\_.upper()) == ['A', 'B', 'C'])
}

pub fn offset-equality() {
    let base = 'hello world'
    let tail = base + 6
    assert(tail == 'world')
    assert(tail == 'world' == true)
    assert(#tail == 5)
    assert(tail.upper() == 'WORLD')
}

pub fn width() {
    assert('abc'.width() == 3)
    assert(''.width() == 0)
}

pub fn long-string() {
    let long = 'x'.repeat(1000)
    assert(#long == 1000)
    assert(long.count('x') == 1000)
    assert(long.scan(/x/).len() == 1000)
    assert(long.sub('x', 'y') == 'y'.repeat(1000))
}

pub fn multiline() {
    let ml = "hello\nworld"
    assert(ml.lines() == ['hello', 'world'])
}
